	# === INDUSTRIAL FOREGOING ===
	quest.2100000000000001.title: "Industrial Foregoing"
	quest.2100000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.2100000000000001.quest_desc: [
		"&6&lINDUSTRIAL FOREGOING&r"
		""
		"O sucessor espiritual do MFR (MineFactory Reloaded). Especializado em &aautomação biológica&r — fazendas, ranches, slaughter."
		""
		"&aMáquinas icônicas:&r"
		"&7• &fPlant Sower / Gatherer&r — fazenda automática"
		"&7• &fAnimal Rancher&r — leite/ovos/lã sem matar"
		"&7• &fMob Slaughter Factory&r — XP + carne"
		"&7• &fBioreactor + Biofuel Generator&r — energia bio"
		"&7• &fBlack Hole Unit&r — armazenamento INFINITO"
		""
		"&aMaterial chave: Plastic.&r"
	]

	quest.2100000000000002.title: "Plastic"
	quest.2100000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000002.quest_desc: [
		"&fO 'plástico industrial' do mod.&r"
		""
		"Faça via Latex (de seringa de árvore) → Plastic Sheet."
		""
		"&7Necessário em quase todas as máquinas IF."
	]

	quest.2100000000000003.title: "Plant Sower"
	quest.2100000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000003.quest_desc: [
		"&aPlanta sementes automaticamente.&r"
		""
		"Defina a área (3x3 a 9x9 com upgrades). Sementes do inventário viram plantation."
		""
		"&7Combine com Plant Gatherer pra fazenda 100% auto."
	]

	quest.2100000000000004.title: "Plant Gatherer"
	quest.2100000000000004.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000004.quest_desc: [
		"&aColhe plantas adultas.&r"
		""
		"Funciona com qualquer cultura: trigo, beterraba, cacau, mystical agriculture."
		""
		"&aSetup ideal:&r Plant Sower + Plant Gatherer = fazenda automática infinita."
	]

	quest.2100000000000005.title: "Animal Rancher"
	quest.2100000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000005.quest_desc: [
		"&aLeite, ovos, lã — sem matar.&r"
		""
		"Range mobs sem violência. Vacas dão leite, ovelhas lã, galinhas ovos."
		""
		"&7Vegano-friendly."
	]

	quest.2100000000000006.title: "Mob Slaughter Factory"
	quest.2100000000000006.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000006.quest_desc: [
		"&cMata mobs e coleta drops.&r"
		""
		"Range hostis. Combine com Powered Spawner (EnderIO) ou mob farm vanilla."
		""
		"&aOutput:&r XP em fluido + Carne (pra Bioreactor)."
	]

	quest.2100000000000007.title: "Bioreactor"
	quest.2100000000000007.quest_subtitle: "&fTier 2 — Vapor"
	quest.2100000000000007.quest_desc: [
		"&aTransforma matéria orgânica em Biofuel.&r"
		""
		"Aceita: trigo, batata, cacau, qualquer planta. Mais &cdiversidade&r de inputs = mais biofuel por slot."
		""
		"&7Combine com Mob Slaughter pra carne + Plant Gatherer pra plantas."
	]

	quest.2100000000000008.title: "Biofuel Generator"
	quest.2100000000000008.quest_subtitle: "&fTier 2 — Vapor"
	quest.2100000000000008.quest_desc: [
		"&aQueima Biofuel pra gerar FE.&r"
		""
		"Output respeitável. Combine com Bioreactor pra base auto-sustentável."
	]

	quest.2100000000000009.title: "Infinity Backpack"
	quest.2100000000000009.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000009.quest_desc: [
		"&dMochila com armazenamento &cILIMITADO&d e funcionalidades infinitas.&r"
		""
		"&fInfinity Backpack&r — guarda milhões de items, alimenta, dá efeitos, e muito mais."
		""
		"&aÚtil pra:&r exploração, ore farms massivas, viagens longas."
	]

	quest.210000000000FFFF.title: "INDUSTRIAL FOREGOING"
	quest.210000000000FFFF.quest_subtitle: "&fTier 2 — Vapor"
	quest.210000000000FFFF.quest_desc: [
		"&6&lAUTOMAÇÃO COMPLETA&r"
		""
		"Você dominou as fazendas auto. O &fLaser Drill&r minera blocos automaticamente sem precisar quebrar nada."
		""
		"&aRecompensa:&r Laser Drill + 1000 XP."
	]

	# === PNEUMATICCRAFT ===
	quest.043F35648E4FE2C0.title: "PneumaticCraft Repressurized"
	quest.043F35648E4FE2C0.quest_subtitle: "&8Tier 0 — Despertar"
	quest.043F35648E4FE2C0.quest_desc: [
		"&6&lPNEUMATICCRAFT&r"
		""
		"O mod &cmais steampunk&r do pack. Pressão de ar como combustível, drones programáveis voando pela base, HUD pneumático."
		""
		"&aConceitos:&r"
		"&7• &fPressão&r — medida em bar (atmosferas)"
		"&7• &fAir Compressor&r — gera pressão queimando combustível"
		"&7• &fPressure Chamber&r — multiblock pra alquimia"
		"&7• &fDrones&r — robôs voadores PROGRAMÁVEIS (puzzle)"
		"&7• &fPneumatic Helmet&r — HUD com módulos"
		""
		"&7Único: aprende-se &eprogramando&r drones com puzzle pieces (similar a Logic Gates)."
	]

	quest.6FF05024B650C29B.title: "Plastic"
	quest.6FF05024B650C29B.quest_subtitle: "&7Tier 1 — Bronze"
	quest.6FF05024B650C29B.quest_desc: [
		"&fO plastic do PneumaticCraft.&r"
		""
		"Faça com Plastic Plant + Pressure Chamber. Necessário em quase tudo."
	]

	quest.2E2C8D28E59555EF.title: "Pressure Tube"
	quest.2E2C8D28E59555EF.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2E2C8D28E59555EF.quest_desc: [
		"&aO 'cabo' do PneumaticCraft.&r"
		""
		"Transmite ar pressurizado entre máquinas. Tem tier que aguenta mais bar."
	]

	quest.7E67EDDB9936EA53.title: "Air Compressor"
	quest.7E67EDDB9936EA53.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7E67EDDB9936EA53.quest_desc: [
		"&fA primeira fonte de pressão.&r"
		""
		"Queima combustíveis (carvão, lava, óleo) pra gerar pressão. Saída em Pressure Tube."
		""
		"&7Tier inicial — limitado em pressão máxima (~5 bar)."
	]

	quest.7CADD78DE22F33E4.title: "Advanced Air Compressor"
	quest.7CADD78DE22F33E4.quest_subtitle: "&fTier 2 — Vapor"
	quest.7CADD78DE22F33E4.quest_desc: [
		"&aTier 2 do compressor.&r"
		""
		"Mais eficiente, suporta mais pressão (~20 bar). Necessário pras máquinas avançadas."
	]

	quest.48275EEDE305EB93.title: "Pressure Chamber Walls"
	quest.48275EEDE305EB93.quest_subtitle: "&fTier 2 — Vapor"
	quest.48275EEDE305EB93.quest_desc: [
		"&fA estrutura da Pressure Chamber.&r"
		""
		"Multiblock 4x4x4 (mínimo). Walls + Glass + 1 Valve."
		""
		"&aFunção:&r alquimia/transmutação. Item dentro + pressão = item transformado (Plastic, Diamond, etc.)"
	]

	quest.2FEE584E62A199A1.title: "Pressure Chamber Valve"
	quest.2FEE584E62A199A1.quest_subtitle: "&fTier 2 — Vapor"
	quest.2FEE584E62A199A1.quest_desc: [
		"&aA porta de entrada.&r"
		""
		"O bloco onde você joga itens e onde sai o produto. Sempre 1 valve por chamber."
	]

	quest.412B83BF31C9D402.title: "Elevator (opcional)"
	quest.412B83BF31C9D402.quest_subtitle: "&fTier 2 — Vapor"
	quest.412B83BF31C9D402.quest_desc: [
		"&aElevador pneumático.&r"
		""
		"Sobe/desce com pressão. Decorativo + funcional."
	]

	quest.2DB351E4F39DD585.title: "Assembly Controller"
	quest.2DB351E4F39DD585.quest_subtitle: "&fTier 2 — Vapor"
	quest.2DB351E4F39DD585.quest_desc: [
		"&aAuto-craft pneumático.&r"
		""
		"Combina items via braços robóticos. Tier alto da automação PneumaticCraft."
	]

	quest.5058A4EDF91569D0.title: "Pneumatic Helmet"
	quest.5058A4EDF91569D0.quest_subtitle: "&fTier 2 — Vapor"
	quest.5058A4EDF91569D0.quest_desc: [
		"&aArmadura tecnológica modular.&r"
		""
		"Aceita módulos: Coordinate Tracker, Air Search, Block Tracker, Entity Tracker, etc."
		""
		"&7Visual de detetive industrial — vê pressão, tracking, X-ray de minérios."
	]

	quest.0ABA02670D74339A.title: "Drone (programável)"
	quest.0ABA02670D74339A.quest_subtitle: "&bTier 3 — Elétrico"
	quest.0ABA02670D74339A.quest_desc: [
		"&dRobô voador PROGRAMÁVEL.&r"
		""
		"Use Drone Programmer pra montar lógica com puzzle pieces:"
		"&7• Move to / Mine / Place / Pickup / Filter"
		""
		"&aO drone executa eternamente. Substitui automação inteira."
	]

	quest.6D4534F9B1BC9496.title: "LOGISTICS DRONE"
	quest.6D4534F9B1BC9496.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6D4534F9B1BC9496.quest_desc: [
		"&6&lENDGAME PNEUMATIC&r"
		""
		"Logistics Drone faz logística complexa via puzzle programming. Você programou um robô que organiza sua base sozinho."
		""
		"&aRecompensa:&r Logistics Drone + 1000 XP."
	]

	# === TFMG ===
	quest.20BB79EACA791D74.title: "TFMG — Things Folks Make Greater"
	quest.20BB79EACA791D74.quest_subtitle: "&8Tier 0 — Despertar"
	quest.20BB79EACA791D74.quest_desc: [
		"&6&lTFMG&r"
		""
		"O addon do Create que adiciona &cREVOLUÇÃO INDUSTRIAL&r de verdade. Diesel, gasolina, distilação de petróleo, cast iron — tudo no estilo steampunk."
		""
		"&aMateriais únicos:&r"
		"&7• &fCast Iron&r — ferro fundido"
		"&7• &fHeavy Plate&r — chapas blindadas"
		"&7• &fIndustrial Iron Block&r — bloco-base"
		""
		"&aMáquinas signature:&r"
		"&7• &fIndustrial Blast Furnace&r — fundição massiva"
		"&7• &fDistillation Tower&r — refino de petróleo"
		"&7• &fDiesel Engine&r — motor potente"
		"&7• &fToolbox&r — caixa de ferramentas"
	]

	quest.54C2AE81263DD0E6.title: "Cast Iron Ingot"
	quest.54C2AE81263DD0E6.quest_subtitle: "&7Tier 1 — Bronze"
	quest.54C2AE81263DD0E6.quest_desc: [
		"&fFerro fundido — base do TFMG.&r"
		""
		"Crafte com Iron + Coal numa receita específica. É mais resistente que ferro normal."
	]

	quest.0C5F867454CCBC6D.title: "Heavy Plate"
	quest.0C5F867454CCBC6D.quest_subtitle: "&7Tier 1 — Bronze"
	quest.0C5F867454CCBC6D.quest_desc: [
		"&fChapa blindada.&r"
		""
		"Press Cast Iron com Mechanical Press. Necessária pras máquinas industriais."
	]

	quest.F100000000000004.title: "Industrial Iron Block"
	quest.F100000000000004.quest_desc: [
		"&aO bloco-base TFMG.&r"
		""
		"Combina Cast Iron + Heavy Plate. Usado em todas as máquinas grandes."
	]

	quest.F100000000000005.title: "Industrial Blast Furnace"
	quest.F100000000000005.quest_desc: [
		"&aFundição massiva.&r"
		""
		"Multiblock — funde minérios em escala industrial. Mais rápido e eficiente que furnace vanilla."
	]

	quest.F100000000000006.title: "Distillation Tower"
	quest.F100000000000006.quest_subtitle: "Refino de petróleo"
	quest.F100000000000006.quest_desc: [
		"&aTorre de destilação fracionada.&r"
		""
		"Multiblock vertical. Recebe &cCrude Oil&r e separa em frações:"
		"&7• Diesel (combustível pesado)"
		"&7• Gasoline (combustível leve)"
		"&7• Lubricant (lubrificante)"
		""
		"&aPure steampunk vibe."
	]

	quest.F100000000000007.title: "Diesel Engine"
	quest.F100000000000007.quest_desc: [
		"&aMotor a diesel/gasolina.&r"
		""
		"Queima combustível pra produzir &eRotação MASSIVA&r (kinetic) ou energia."
		""
		"&7Substitui Steam Engine pra setups industriais."
	]

	quest.0E450ECBE856DAD6.title: "Diesel e Gasoline"
	quest.0E450ECBE856DAD6.quest_subtitle: "&bTier 3 — Elétrico"
	quest.0E450ECBE856DAD6.quest_desc: [
		"&aOs combustíveis líquidos.&r"
		""
		"Saída da Distillation Tower. Diesel = mais energia/tempo. Gasoline = mais rápido."
		""
		"&7Combine com Diesel Engine pra full setup industrial."
	]

	quest.F100000000000009.title: "Toolbox (opcional)"
	quest.F100000000000009.quest_desc: [
		"&fCaixa de ferramentas.&r"
		""
		"Carrega ferramentas e troca rápido. Estética industrial."
	]

	quest.F10000000000FFFF.title: "REVOLUÇÃO INDUSTRIAL"
	quest.F10000000000FFFF.quest_desc: [
		"&6&lTFMG COMPLETO&r"
		""
		"Você abriu uma refinaria. Diesel Engine rodando, Distillation Tower fervendo petróleo. A Era Industrial começou."
		""
		"&aRecompensa:&r 8× Industrial Iron Block + 1000 XP."
	]

	# === TRAINS ===
	quest.7400000000000001.title: "Create Trains / Railways"
	quest.7400000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.7400000000000001.quest_desc: [
		"&6&lTRENS DO CREATE&r"
		""
		"Sistema de trens completo. Construa rotas, agende horários, transporte itens em massa."
		""
		"&aComponentes core:&r"
		"&7• &fTrack&r — trilhos curvos, retos, junções"
		"&7• &fTrack Station&r — controle de estações"
		"&7• &fTrack Signal&r — sinalização entre trens"
		"&7• &fSchedule&r — rotas automáticas"
		"&7• &fRailway Casing&r — construção"
		""
		"&aRailways addon:&r adiciona trilhos especiais (glow, brass, andesite)."
	]

	quest.7400000000000002.title: "Track (Trilho)"
	quest.7400000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7400000000000002.quest_desc: [
		"&fO trilho base.&r"
		""
		"Track Tool permite construir trilhos curvos automaticamente. Ponha 2 tracks, conecta via tool, e ele preenche."
	]

	quest.7400000000000003.title: "Railway Casing"
	quest.7400000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7400000000000003.quest_desc: [
		"&fO bloco-base de máquinas ferroviárias.&r"
		""
		"Necessário pra Track Station, Schedule, Signal."
	]

	quest.7400000000000004.title: "Track Station"
	quest.7400000000000004.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000004.quest_desc: [
		"&aA estação de trem.&r"
		""
		"Onde trens param, embarcam passageiros, carregam/descarregam. Cada estação tem nome único."
	]

	quest.7400000000000005.title: "Track Signal"
	quest.7400000000000005.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000005.quest_desc: [
		"&aSinalização ferroviária.&r"
		""
		"Previne colisões entre trens. Você define blocos de sinal — só 1 trem entra por vez."
	]

	quest.7400000000000006.title: "Track Observer"
	quest.7400000000000006.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000006.quest_desc: [
		"&aDetecta trens passando.&r"
		""
		"Emite redstone quando trem passa. Útil pra automação."
	]

	quest.7400000000000007.title: "Train Schedule"
	quest.7400000000000007.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000007.quest_desc: [
		"&aHorários automáticos.&r"
		""
		"Programe destinos. O trem segue rotas sozinho. Pode esperar X tempo, descarregar, etc."
	]

	quest.7400000000000008.title: "Train Doors"
	quest.7400000000000008.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000008.quest_desc: [
		"&aPortas que abrem em estações.&r"
		""
		"Train Door + Trapdoor. Abrem automaticamente quando o trem encosta na estação."
	]

	quest.7400000000000009.title: "Glow Track (Railways)"
	quest.7400000000000009.quest_subtitle: "&fTier 2 — Vapor"
	quest.7400000000000009.quest_desc: [
		"&eTrilho que brilha.&r"
		""
		"Decorativo + funcional. Outros trilhos especiais via Railways: brass, andesite, copper."
	]

	quest.740000000000FFFF.title: "REDE FERROVIÁRIA"
	quest.740000000000FFFF.quest_subtitle: "&bTier 3 — Elétrico"
	quest.740000000000FFFF.quest_desc: [
		"&6&lINFRAESTRUTURA COMPLETA&r"
		""
		"Você construiu uma rota com 2+ estações + schedule funcional. Trens andam sozinhos."
		""
		"&aRecompensa:&r 32× Track + 1000 XP."
	]

	# === AERONAUTICS ===
	quest.61B84C4C401F3627.title: "Create Aeronautics — Dirigíveis"
	quest.61B84C4C401F3627.quest_subtitle: "&8Tier 0 — Despertar"
	quest.61B84C4C401F3627.quest_desc: [
		"&6&lAERONAUTICS&r"
		""
		"Construa &cAIRSHIPS&r voadores. Vibe steampunk pura — dirigíveis com motor a vapor."
		""
		"&aComponentes:&r"
		"&7• &fAirship Casing&r — estrutura"
		"&7• &fHelm&r — controle"
		"&7• &fPropeller&r — propulsão"
		"&7• &fFloater&r — sustentação anti-gravity"
		""
		"&7Construa, monte, decole. Pode levar baús, máquinas, até estruturas inteiras."
	]

	quest.8500000000000002.title: "Airship Casing"
	quest.8500000000000002.quest_desc: [
		"&fO bloco-base do dirigível.&r"
		""
		"Construa o esqueleto do airship com Casing. Forma o corpo da nave."
	]

	quest.8500000000000003.title: "Propeller"
	quest.8500000000000003.quest_desc: [
		"&aA hélice de propulsão.&r"
		""
		"Conectada a Steam Engine ou outro motor de rotação, propulsiona o airship."
	]

	quest.8500000000000004.title: "Helm"
	quest.8500000000000004.quest_desc: [
		"&aO leme — onde você pilota.&r"
		""
		"Right-click pra entrar. WASD pra mover. Olhar pra direção."
	]

	quest.8500000000000005.title: "Floater"
	quest.8500000000000005.quest_desc: [
		"&aA sustentação anti-gravity.&r"
		""
		"Coloque vários no chassi. Quanto mais Floaters, mais peso o airship aguenta."
	]

	quest.850000000000FFFF.title: "PRIMEIRO VOO"
	quest.850000000000FFFF.quest_desc: [
		"&6&lDECOLAGEM&r"
		""
		"Você construiu um airship completo e voou. Sem mais ficar preso ao chão."
		""
		"&aRecompensa:&r Helm + 1000 XP."
	]

	# === BIG CANNONS ===
	quest.7BBEAFCE05EE1CC8.title: "Big Cannons — Artilharia"
	quest.7BBEAFCE05EE1CC8.quest_subtitle: "&8Tier 0 — Despertar"
	quest.7BBEAFCE05EE1CC8.quest_desc: [
		"&6&lCREATE BIG CANNONS&r"
		""
		"Canhões de pólvora estilo navio de guerra. Compatível com airships pra defesa aérea."
