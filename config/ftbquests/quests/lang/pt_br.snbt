	# === INÍCIO — Bem-vindo ===
	quest.1B4201991EE0CC14.title: "Tecmod Arena BR — O Legado Não Morre"
	quest.1B4201991EE0CC14.quest_subtitle: "&8Tier 0 — Despertar"
	quest.1B4201991EE0CC14.quest_desc: [
		"&6&lBem-vindo, aventureiro!&r"
		""
		"Você está prestes a entrar em um mundo onde &btecnologia&r, &dmagia&r e &ccombate&r se encontram em uma única jornada épica."
		""
		"&eEste pack tem como tema central a &6indústria steampunk&e — engrenagens, vapor, raio domesticado e plasma."
		""
		"&7Use este &flivro de quests&7 como guia. Ele vai te mostrar:"
		"&7• Como começar com cada mod"
		"&7• Como integrar mods entre si"
		"&7• Objetivos para te dar direção"
		""
		"&aBoa sorte. O Legado Não Morre."
		""
		"&8Pack feito por: &7Arena BR O Legado Não Morre"
	]

	quest.1DEF751E3E868662.title: "Pegue uma Picareta de Madeira"
	quest.1DEF751E3E868662.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1DEF751E3E868662.quest_desc: [
		"Toda jornada começa com o básico."
		""
		"Quebre madeira, faça pranchas, faça gravetos e por fim uma &fpicareta de madeira&r."
		""
		"Você vai precisar dela pra começar a minerar pedra e ferro."
	]

	quest.2EF852A4F979DC73.title: "Picareta de Pedra"
	quest.2EF852A4F979DC73.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2EF852A4F979DC73.quest_desc: [
		"Com a picareta de madeira, mine 3 pedras e faça uma &7picareta de pedra&r."
		""
		"Agora você consegue minerar &fferro&r e &fcobre&r."
	]

	quest.3FA963B5081AED84.title: "Primeiro Ferro"
	quest.3FA963B5081AED84.quest_subtitle: "&fTier 2 — Vapor"
	quest.3FA963B5081AED84.quest_desc: [
		"Mine &fminério de ferro&r e queime no forno."
		""
		"Ferro é a base de quase tudo nos mods de tecnologia."
		""
		"&7Dica: na pasta &eIndústria e Tech&7 do livro tem guias para Create, Mekanism e mais."
	]

	quest.4AB074C61920FEA5.title: "Cama Segura"
	quest.4AB074C61920FEA5.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4AB074C61920FEA5.quest_desc: [
		"&eOpcional&r — mas altamente recomendado."
		""
		"Faça uma &ccama&r e durma a primeira noite. Define seu ponto de respawn e pula a noite."
		""
		"&cAtenção:&r se estiver com o &5Anel da Maldição&r equipado, morrer custa caro!"
	]

	quest.5BC185D72A31019B.title: "Comida Decente"
	quest.5BC185D72A31019B.quest_subtitle: "&7Tier 1 — Bronze"
	quest.5BC185D72A31019B.quest_desc: [
		"&eOpcional&r — mas você vai morrer de fome senão."
		""
		"Plante &etrigo&r ou ache &fovelhas&r. Faça pão ou cozinhe carne."
		""
		"Veja a categoria &aAgricultura&r pra opções avançadas (Farmer's Delight, Mystical Agriculture)."
	]

	quest.6CD296E83B42120C.title: "Próximos Passos"
	quest.6CD296E83B42120C.quest_subtitle: "&fTier 2 — Vapor"
	quest.6CD296E83B42120C.quest_desc: [
		"&6Você completou o básico!&r"
		""
		"Agora escolha seu caminho:"
		""
		"&bIndústria e Tech&r - Create, Mekanism, IE, Powah, Pneumatic..."
		"&dMagia&r - Ars Nouveau, Iron's Spellbooks, Forbidden Arcanus"
		"&cCombate&r - Apotheosis, Enigmatic Legacy, Cataclysm"
		"&aAgricultura&r - Mystical, Farmer's Delight"
		"&eLogística&r - AE2, Refined Storage"
		"&6Transporte&r - Trains, Aeronautics, Aircraft"
		""
		"&7Cada mod tem seu próprio capítulo com a jornada completa do início ao endgame."
	]

	# === CREATE ===
	quest.176B7C69004C0933.title: "Create — A Era do Vapor"
	quest.176B7C69004C0933.quest_subtitle: "&8Tier 0 — Despertar"
	quest.176B7C69004C0933.quest_desc: [
		"&6&lA ERA DO VAPOR DESPERTA&r"
		""
		"O ferro pesa. A pedra é morta. Mas no instante em que a primeira engrenagem morde a outra — o mundo muda."
		""
		"&eCreate&r não é magia. É &cmecânica pura&r:"
		"&7• &fEixos (Shafts)&r — transmitem rotação"
		"&7• &fEngrenagens (Cogs)&r — distribuem"
		"&7• &fMáquinas&r — consomem rotação"
		"&7• Tudo medido em &eRPM&r e &cStress (SU)&r"
		""
		"&aProgressão deste capítulo:"
		"&71. &7Andesite Tier &8(básico)"
		"&72. &6Brass Tier &8(intermediário)"
		"&73. &cCopper Tier &8(fluidos)"
		"&74. &bSteam Tier &8(endgame: Steam Engine)"
		""
		"&7Pressione &eW&r em itens do Create no JEI/EMI para ver o &fPonder&r — animação ensinando o uso!"
	]

	quest.7D155B8706B2E0B7.title: "Andesite Alloy"
	quest.7D155B8706B2E0B7.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7D155B8706B2E0B7.quest_desc: [
		"O ingrediente fundador da era mecânica."
		""
		"&7Receita:&r 1 Iron Nugget + 1 Andesite no Crafting Table."
		""
		"&aDica:&r você vai gastar &eMUITO&r isso. Vale automatizar com Mechanical Mixer mais tarde."
	]

	quest.34CE79FE6AA985F7.title: "Manivela (Hand Crank)"
	quest.34CE79FE6AA985F7.quest_subtitle: "&7Tier 1 — Bronze"
	quest.34CE79FE6AA985F7.quest_desc: [
		"Sua &eprimeira fonte de energia&r."
		""
		"Segurando o botão direito, gera 32 SU. Bom o suficiente pra alimentar 1-2 máquinas pequenas."
		""
		"&aÚtil para:&r testar setups antes de Water Wheel."
	]

	quest.436144EA8277664D.title: "Eixos e Engrenagens"
	quest.436144EA8277664D.quest_subtitle: "&7Tier 1 — Bronze"
	quest.436144EA8277664D.quest_desc: [
		"&fOs nervos da fábrica.&r"
		""
		"&fShaft (Eixo)&r — transmite em linha reta"
		"&fCogwheel (Engrenagem)&r — transmite entre eixos paralelos"
		"&fLarge Cogwheel&r — multiplica/divide velocidade"
		""
		"&aMantenha 8+ de cada no inventário sempre."
	]

	quest.1396DB05C5723254.title: "Roda d'Água"
	quest.1396DB05C5723254.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1396DB05C5723254.quest_desc: [
		"&bEnergia limpa, infinita, gratuita.&r"
		""
		"Coloque numa corrente de água com fluxo nas 4 faces — gera RPM contínuo sem combustível."
		""
		"&aMelhor opção early-game para automação 24/7."
	]

	quest.226F2BE5DD2E0F99.title: "Millstone"
	quest.226F2BE5DD2E0F99.quest_subtitle: "&7Tier 1 — Bronze"
	quest.226F2BE5DD2E0F99.quest_desc: [
		"&fTriture com rotação.&r"
		""
		"O Millstone moe minérios em pó (1 ore = 1 dust). Funciona com qualquer rotação."
		""
		"&7Receita: Andesite Casing + Cogwheel"
		""
		"&aÚtil para:&r dobrar minério antes de tier 2."
	]

	quest.2B6251F07FA3B496.title: "Mechanical Press"
	quest.2B6251F07FA3B496.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2B6251F07FA3B496.quest_desc: [
		"&fComprime e prensa com força mecânica.&r"
		""
		"Coloque sobre &eDepot&r ou &fBelt&r com itens. Press transforma:"
		"&7• Iron Ingot → Iron Sheet"
		"&7• Gold Ingot → Gold Sheet"
		"&7• Etc."
		""
		"&aTambém usado em &eSequenced Assembly&r mais tarde!"
	]

	quest.1677F1148A3C4239.title: "Encased Fan"
	quest.1677F1148A3C4239.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1677F1148A3C4239.quest_desc: [
		"&fO ventilador alquímico.&r"
		""
		"Aponta pra:"
		"&7• &cFogo&r → forno (smoke)"
		"&7• &bÁgua&r → lava itens (washing → minério → 2 chunks)"
		"&7• &eAr puro&r → empurra itens"
		""
		"&aWashing duplica minério com cobre, ouro, etc!"
	]

	quest.4BBC6D3EF87C565C.title: "Mechanical Mixer"
	quest.4BBC6D3EF87C565C.quest_subtitle: "&fTier 2 — Vapor"
	quest.4BBC6D3EF87C565C.quest_desc: [
		"&aO coração da metalurgia automatizada.&r"
		""
		"Setup: &fBasin&r no chão, &fMixer&r 2 blocos acima, eixo conectado."
		""
		"Combina items + fluidos automaticamente. Receita básica:"
		"&7Andesite + Iron Nugget → Andesite Alloy"
		""
		"&aPróximo passo:&r Brass!"
	]

	quest.34148A6C4BAF251E.title: "Latão (Brass)"
	quest.34148A6C4BAF251E.quest_subtitle: "&fTier 2 — Vapor"
	quest.34148A6C4BAF251E.quest_desc: [
		"&6Material tier 2 do Create.&r"
		""
		"&7Receita no Mixer:&r"
		"&7• Cobre + Zinco → Brass Ingot"
		""
		"&aBrass desbloqueia:&r Mechanical Crafter, Arm, Belts, Funnels avançados, Sequenced Assembly."
	]

	quest.6CA513ADDC7C0FB0.title: "Brass Casing"
	quest.6CA513ADDC7C0FB0.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6CA513ADDC7C0FB0.quest_desc: [
		"&6O bloco-base de máquinas tier 2.&r"
		""
		"&7Receita: Stripped Wood + Brass Sheets (Press)"
		""
		"&aBase para:&r Mechanical Crafter, Arm, e maioria de máquinas avançadas."
	]

	quest.2710F631C50E0588.title: "Mechanical Crafter"
	quest.2710F631C50E0588.quest_subtitle: "&bTier 3 — Elétrico"
	quest.2710F631C50E0588.quest_desc: [
		"&aCrafting automático em forma!&r"
		""
		"Use em grade (3x3 ou maior). Configure setas com &eWrench&r — formam um caminho."
		""
		"Cada Crafter recebe 1 ingrediente. O resultado sai pelo último."
		""
		"&aIdeal para:&r Refined Radiance, Shadow Steel, e receitas complexas como Steel Casing."
	]

	quest.43E8C0D7F4FEB8A2.title: "Mechanical Arm"
	quest.43E8C0D7F4FEB8A2.quest_subtitle: "&bTier 3 — Elétrico"
	quest.43E8C0D7F4FEB8A2.quest_desc: [
		"&6O braço robótico programável.&r"
		""
		"Programa via Wrench (clica em inputs e outputs). Pega itens de até 5 fontes e distribui pra 5 destinos."
		""
		"&aPerfeito para:&r alimentar Crafters, separar minérios, organizar saída de Sequenced Assembly."
	]

	quest.08537810BFF8B039.title: "Depot"
	quest.08537810BFF8B039.quest_subtitle: "&bTier 3 — Elétrico"
	quest.08537810BFF8B039.quest_desc: [
		"&fA mesa estática.&r"
		""
		"Diferente do Belt, o Depot &csegura&r o item para Press, Deployer e outros agirem."
		""
		"&aEssencial para Sequenced Assembly Lines."
	]

	quest.2288949B35AC2389.title: "Precision Mechanism"
	quest.2288949B35AC2389.quest_subtitle: "&dTier 4 — Avançado"
	quest.2288949B35AC2389.quest_desc: [
		"&6&lO ITEM ENDGAME DO TIER BRASS&r"
		""
		"Feito numa &eSequenced Assembly&r de 5+ etapas:"
		"&71. Golden Sheet entra"
		"&72. Deployer aplica Cogwheel"
		"&73. Deployer aplica Iron Nugget"
		"&74. Press martela"
		"&75. (loop várias vezes)"
		"&76. Resultado: &6Precision Mechanism&r"
		""
		"&aPré-requisito para:&r Copper Casing, Steam Engine, e máquinas tier alto."
	]

	quest.67E87541D256594D.title: "Copper Casing"
	quest.67E87541D256594D.quest_subtitle: "&dTier 4 — Avançado"
	quest.67E87541D256594D.quest_desc: [
		"&cO casing de fluidos.&r"
		""
		"Necessário para máquinas que &emanipulam líquidos&r — Spouts, Fluid Tanks, Pipes, Pumps."
		""
		"&7Receita:&r requer Precision Mechanism + Copper Sheets."
	]

	quest.51844225E70C5F9E.title: "Spouts e Pipes"
	quest.51844225E70C5F9E.quest_subtitle: "&6Tier 5 — Endgame"
	quest.51844225E70C5F9E.quest_desc: [
		"&aMovimentação de fluidos.&r"
		""
		"&fSpout&r — derrama fluido em itens (encantar potions, lava de obsidiana)"
		"&fFluid Pipe&r — transporta fluidos como Belt para itens"
		""
		"&aCombine com &eHose Pulley&r pra sugar oceanos!"
	]

	quest.373A2D45AB27B906.title: "Tanks e Vaults"
	quest.373A2D45AB27B906.quest_subtitle: "&6Tier 5 — Endgame"
	quest.373A2D45AB27B906.quest_desc: [
		"&fArmazenamento em escala.&r"
		""
		"&fFluid Tank&r — guarda 8000 mB. Multiblock pra capacidade maior!"
		"&fItem Vault&r — guarda itens, multiblock pra escala industrial."
		""
		"&aBoth multiblocks crescem em altura/largura sem tampa."
	]

	quest.72C3443AF01CC125.title: "Blaze Burner"
	quest.72C3443AF01CC125.quest_subtitle: "&6Tier 5 — Endgame"
	quest.72C3443AF01CC125.quest_desc: [
		"&cO coração do vapor.&r"
		""
		"Captura um Blaze do Nether num Empty Blaze Burner. Alimenta com:"
		"&7• Carvão, madeira (heat normal)"
		"&7• Lava, blaze rod, óleo (super heated!)"
		""
		"&aSuper-heated é necessário pra Steam Engine atingir potência máxima."
	]

	quest.733745D9E94FF334.title: "Steam Engine"
	quest.733745D9E94FF334.quest_subtitle: "&6Tier 5 — Endgame"
	quest.733745D9E94FF334.quest_desc: [
		"&6&lA MÁQUINA QUE DEFINE A ERA&r"
		""
		"Setup completo:"
		"&71. &fBlaze Burner&r super-heated"
		"&72. &fFluid Tank&r de água em cima"
		"&73. &eSteam Engine&r conectado lateralmente"
		"&74. Mais Engines = mais SU (até &c1024 SU&r por engine!)"
		""
		"&aSubstitui 4-8 Water Wheels. Realmente endgame de kinetic."
	]

	quest.0883606D192C5230.title: "Mechanical Saw"
	quest.0883606D192C5230.quest_subtitle: "&dTier 4 — Avançado"
	quest.0883606D192C5230.quest_desc: [
		"&fCorta tudo em sua frente.&r"
		""
		"&7Funções:&r"
		"&7• Aponta pra árvore → derruba e processa em prancha"
		"&7• Aponta pro chão (Belt) → corta itens (madeira → planks, etc.)"
		""
		"&aOpcional&r mas extremamente útil pra fazendas de madeira."
	]

	quest.02943C4C749395F8.title: "Mechanical Pump"
	quest.02943C4C749395F8.quest_subtitle: "&dTier 4 — Avançado"
	quest.02943C4C749395F8.quest_desc: [
		"&fMove fluidos.&r"
		""
		"Conectada a Fluid Pipes, força o sentido do fluxo."
		""
		"&aOpcional&r mas necessária pra distribuir fluidos em escala."
	]

	quest.6AC5E3282FF0AE0D.title: "Schematicannon"
	quest.6AC5E3282FF0AE0D.quest_subtitle: "&dTier 4 — Avançado"
	quest.6AC5E3282FF0AE0D.quest_desc: [
		"&fConstrói prédios automaticamente!&r"
		""
		"Carrega um schematic (.nbt) e dispara blocos do inventário pra construir tudo."
		""
		"&7Limitações:&r consome gunpowder + os blocos. Não constrói entidades."
		""
		"&aPerfeito para:&r reproduzir bases inteiras."
	]

	quest.484328FBEA2EEDA0.title: "IMPÉRIO DA INDÚSTRIA"
	quest.484328FBEA2EEDA0.quest_subtitle: "&6Tier 5 — Endgame"
	quest.484328FBEA2EEDA0.quest_desc: [
		"&6&lOBJETIVO FINAL DO CREATE&r"
		""
		"Provê 8 Precision Mechanisms — produzidos automaticamente."
		""
		"&7Setup esperado:"
		"&71. Steam Engine alimentando a fábrica"
		"&72. Mechanical Crafters em grade fazendo a sequência"
		"&73. Mechanical Arms distribuindo itens"
		"&74. AE2/Storage colocando insumos"
		""
		"&aRecompensa:&r material para a próxima Era — &fNetherite Ingot&r + 1000 XP."
		""
		"&7Próximos capítulos sugeridos: Mekanism, Immersive Engineering, ou Pneumática."
	]

	# === MYSTICAL AGRICULTURE ===
	quest.064E42EE76F3EC2B.title: "Bem-vindo à Mystical Agriculture"
	quest.064E42EE76F3EC2B.quest_subtitle: "&8Tier 0 — Despertar"
	quest.064E42EE76F3EC2B.quest_desc: [
		"&6&lMYSTICAL AGRICULTURE&r"
		""
		"E se você pudesse plantar &fferro&r? &fdiamantes&r? &fnetherite&r?"
		""
		"Esse mod permite cultivar &equase qualquer recurso&r do jogo através de sementes mágicas."
		""
		"&aA progressão funciona em tiers de essências:"
		"&7• &aInferium&r (Tier 1) — base de tudo"
		"&7• &eProdentium&r (Tier 2) — desbloqueia metais"
		"&7• &6Tertium&r (Tier 3) — diamantes, esmeraldas"
		"&7• &cImperium&r (Tier 4) — netherite, materiais raros"
		"&7• &dSupremium&r (Tier 5) — fim de jogo"
		""
		"Cada tier requer 4× do anterior + crystal central no &fInfusion Altar&r."
	]

	quest.559F919D460558D8.title: "Prosperity Shards"
	quest.559F919D460558D8.quest_subtitle: "&7Tier 1 — Bronze"
	quest.559F919D460558D8.quest_desc: [
		"O ingrediente inicial do mod."
		""
		"&fProsperity Shards&r dropam de &eProsperity Ore&r — minério rosa que aparece no overworld."
		""
		"&aDica:&r explore cavernas em Y:30-50 pra achar."
	]

	quest.3528811DC40B62C5.title: "Infusion Crystal"
	quest.3528811DC40B62C5.quest_subtitle: "&7Tier 1 — Bronze"
	quest.3528811DC40B62C5.quest_desc: [
		"&fO 'cérebro' das infusões.&r"
		""
		"O Infusion Crystal é usado no centro do &eInfusion Altar&r pra subir de tier."
		""
		"&7Receita:&r 4 Prosperity Shard + 4 Diamonds + 1 Crystal Block"
		""
		"&aO crystal tem durabilidade — cada infusão gasta 1 ponto."
	]

	quest.74649FD50729E125.title: "Inferium Essence (Tier 1)"
	quest.74649FD50729E125.quest_subtitle: "&fTier 2 — Vapor"
	quest.74649FD50729E125.quest_desc: [
		"&aInferium&r é a essência básica do mod."
		""
		"&7Como obter:"
		"&7• Plante &fInferium Seeds&r → colha &fInferium Crops&r → vira essência"
		"&7• Mate mobs (drop pequena chance)"
		"&7• Mine Inferium Ore"
		""
		"&aUso:&r ingrediente pra TODAS as outras sementes do mod."
	]

	quest.3853204B902E6170.title: "Prudentium Essence (Tier 2)"
	quest.3853204B902E6170.quest_subtitle: "&fTier 2 — Vapor"
	quest.3853204B902E6170.quest_desc: [
		"&eTier 2&r — desbloqueia &fmetais comuns&r como sementes."
		""
		"&7Receita Infusion Altar:"
		"&7• 8× Inferium Essence"
		"&7• 1× Prosperity Shard"
		"&7• Resultado: 1× Prudentium"
		""
		"&aDesbloqueia sementes de:&r ferro, cobre, lapis, redstone, etc."
	]

	quest.0B93BD9F76B650A2.title: "Tertium Essence (Tier 3)"
	quest.0B93BD9F76B650A2.quest_subtitle: "&bTier 3 — Elétrico"
	quest.0B93BD9F76B650A2.quest_desc: [
		"&6Tier 3&r — recursos &fmédios&r."
		""
		"&7Receita: 8× Prudentium + crystal central"
		""
		"&aDesbloqueia:&r ouro, esmeralda, diamante, sementes de mob (zumbi, esqueleto)."
	]

	quest.105DC71328FAAB35.title: "Imperium Essence (Tier 4)"
	quest.105DC71328FAAB35.quest_subtitle: "&bTier 3 — Elétrico"
	quest.105DC71328FAAB35.quest_desc: [
		"&cTier 4&r — recursos &fraros&r."
		""
		"&7Receita: 8× Tertium + crystal central"
		""
		"&aDesbloqueia:&r netherite, dragão, mobs do nether/end."
	]

	quest.33E3301A6F1FE333.title: "Supremium Essence (Tier 5)"
	quest.33E3301A6F1FE333.quest_subtitle: "&dTier 4 — Avançado"
	quest.33E3301A6F1FE333.quest_desc: [
		"&dTier 5 — Supremium&r"
		""
		"O ápice das essências comuns."
		""
		"&7Receita: 8× Imperium + crystal central"
		""
		"&aDesbloqueia:&r itens endgame, armaduras Supremium, e prepara pro &6Awakened Supremium&r."
	]

	quest.13911A59D4C45076.title: "Sementes de Ferro"
	quest.13911A59D4C45076.quest_subtitle: "&fTier 2 — Vapor"
	quest.13911A59D4C45076.quest_desc: [
		"&fIron Seeds&r — sua primeira semente de metal!"
		""
		"&7Receita Infusion Altar:&r"
		"&7• 4× Prudentium Essence + 4× Iron Ingot + crystal"
		""
		"&aPlante em farmland e regue. Em poucos minutos: &eIron Crops&r → ingot direto!"
	]

	quest.2349FECB9B9FC2F8.title: "Sementes de Cobre"
	quest.2349FECB9B9FC2F8.quest_subtitle: "&fTier 2 — Vapor"
	quest.2349FECB9B9FC2F8.quest_desc: [
		"Similar ao ferro, mas com cobre."
		""
		"&aÓtimo pra:&r alimentar Mekanism (cobre é base de cabos elétricos)."
	]

	quest.4A3C0838CD577E48.title: "Sementes de Ouro"
	quest.4A3C0838CD577E48.quest_subtitle: "&bTier 3 — Elétrico"
	quest.4A3C0838CD577E48.quest_desc: [
		"&6Gold Seeds&r — Tier 2 (Prudentium)."
		""
		"&7Receita: 4× Prudentium + 4× Gold Ingot + crystal"
	]

	quest.7D15B392B0C6899A.title: "Sementes de Diamante"
	quest.7D15B392B0C6899A.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7D15B392B0C6899A.quest_desc: [
		"&bDiamond Seeds&r — Tier 3 (Tertium)."
		""
		"&aImpressionante:&r você está literalmente plantando diamantes."
	]

	quest.70A898226C1D84FF.title: "Sementes de Netherite"
	quest.70A898226C1D84FF.quest_subtitle: "&dTier 4 — Avançado"
	quest.70A898226C1D84FF.quest_desc: [
		"&8Netherite Seeds&r — Tier 4 (Imperium)."
		""
		"&7Necessário ter o Imperium funcionando primeiro."
		""
		"&aCom isso você nunca mais precisa ir ao Nether pra netherite!"
	]

	quest.41A496CF2A5EE15F.title: "Awakened Supremium"
	quest.41A496CF2A5EE15F.quest_subtitle: "&dTier 4 — Avançado"
	quest.41A496CF2A5EE15F.quest_desc: [
		"&dAwakened Supremium&r"
		""
		"Versão &cdespertada&r do Supremium. Necessária pra equipamentos endgame."
		""
		"&7Receita: Awakening no Awakening Altar (estrutura grande, requer 4 awakening pillars com gemas)"
		""
		"&aÚtil pra:&r Supremium Sword (5x dano), Supremium Pickaxe (auto-fortune), Supremium Armor (immortality charm)."
	]

	quest.5BD5BE21BF8D22AD.title: "Estoque de Inferium"
	quest.5BD5BE21BF8D22AD.quest_subtitle: "&fTier 2 — Vapor"
	quest.5BD5BE21BF8D22AD.quest_desc: [
		"&6Acumule recursos para subir de tier!&r"
		""
		"Cada upgrade de essência (Inferium → Prudentium → Tertium...) requer &c8 essências do tier anterior&r no Infusion Altar."
		""
		"&7Estoca 8 Inferium Essence para garantir progresso."
		""
		"&aDica:&r faça um Growth Accelerator (item do mod) embaixo da farmland — acelera muito o crescimento das suas plantas Mystical."
	]

	quest.4E56BECD28B67BE2.title: "Soulium Dagger (opcional)"
	quest.4E56BECD28B67BE2.quest_subtitle: "&bTier 3 — Elétrico"
	quest.4E56BECD28B67BE2.quest_desc: [
		"&eOpcional&r — pra coletar essências de mob."
		""
		"Mata mobs com a Soulium Dagger pra obter &fMob Chunks&r — usados pra fazer mob seeds (zumbi, esqueleto, etc.)"
		""
		"&7Soulium é uma liga: 4× Prudentium + 4× Soulstone (drop de Endermans)"
	]

	quest.60DEF1DBB8ADA48C.title: "OBJETIVO: Espada Suprema"
	quest.60DEF1DBB8ADA48C.quest_subtitle: "&6Tier 5 — Endgame"
	quest.60DEF1DBB8ADA48C.quest_desc: [
		"&6&lDESAFIO ENDGAME&r"
		""
		"Crafte uma &dSupremium Sword&r — uma das melhores armas do pack."
		""
		"&7Como:&r"
		"&71. Tenha Awakened Supremium funcionando"
		"&72. Crafte Supremium Sword Blade"
		"&73. Junte com cabo de prosperity"
		"&74. (Opcional) infunda com gemas pra customizar"
		""
		"&aRecompensa:&r 4× Supremium Helmet + base pra full set."
	]

	# === STORAGE / ARMAZENAMENTO ===
	quest.7A00000000000001.title: "Armazenamento — Onde guardar tudo"
	quest.7A00000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.7A00000000000001.quest_desc: [
		"&6&lARMAZENAMENTO INDUSTRIAL&r"
		""
		"Toda fábrica precisa de um lugar pra guardar matéria-prima e produtos finais. Esse pack te dá &cmuitas opções&r — cada uma com sua progressão."
		""
		"&aArmazenamento físico (este capítulo):&r"
		"&7• &fSophisticated Storage&r — barris/baús com tier (Iron → Netherite)"
		"&7• &fFunctional Storage&r — drawers individuais por item, com controlador"
		"&7• &fIron Chests&r — baús maiores tier-by-tier"
		"&7• &fSophisticated Backpacks&r — armazenamento portátil"
		"&7• &fEnder Storage&r — baús linkados por frequência"
		"&7• &eTrash Cans + Travelers Backpack&r &7(opcionais)"
		""
		"&aArmazenamento digital (capítulos separados):&r"
		"&7• &bRefined Storage&r - rede digital simples"
		"&7• &bApplied Energistics 2 (AE2)&r - rede digital avançada com auto-craft"
		""
		"&7Você não precisa fazer todas as árvores. Escolha 1 ou faça todas."
	]

	quest.7A00000000000010.title: "Sophisticated — Barril Básico"
	quest.7A00000000000010.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000010.quest_desc: [
		"&fO ponto de partida da árvore Sophisticated.&r"
		""
		"&aO barril básico já aceita upgrades:&r Stack (mais slots), Compaction (auto-compactar), Magnet, etc."
		""
		"&7Receita:&r 4 tábuas + 4 slabs"
	]

	quest.7A00000000000011.title: "Sophisticated — Iron Tier"
	quest.7A00000000000011.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000011.quest_desc: [
		"Upgrade pro tier ferro — &c+9 slots&r e mais 1 slot pra upgrade."
		""
		"&aBarris/baús são compatíveis com upgrades transferíveis."
	]

	quest.7A00000000000012.title: "Sophisticated — Gold Tier"
	quest.7A00000000000012.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000012.quest_desc: [
		"&6Tier ouro&r — mais slots, mais upgrades."
		""
		"&aDica:&r o Gold Tier desbloqueia capacidade XP e mais magnet range."
	]

	quest.7A00000000000013.title: "Sophisticated — Diamond Tier"
	quest.7A00000000000013.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000013.quest_desc: [
		"&bTier diamante&r — quase endgame."
		""
		"&aBarris diamante começam a competir com drawers em capacidade pura."
	]

	quest.7A00000000000014.title: "Sophisticated — Netherite Tier"
	quest.7A00000000000014.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7A00000000000014.quest_desc: [
		"&8Endgame da árvore Sophisticated.&r"
		""
		"Resistente a explosão, máximo de slots, máximo de upgrades suportados."
		""
		"&aRecompensa:&r 100 XP."
	]

	quest.7A00000000000020.title: "Functional Storage — Drawer Simples"
	quest.7A00000000000020.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000020.quest_desc: [
		"&fUm slot, um item, infinitos.&r"
		""
		"Drawers guardam &cum tipo&r de item, mas em quantidade massiva."
		""
		"&aClique pra retirar 1 stack. Shift+click pra retirar tudo."
	]

	quest.7A00000000000021.title: "Functional Storage — Drawers Múltiplos"
	quest.7A00000000000021.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000021.quest_desc: [
		"&aDrawer 2x e 4x — mais tipos de itens por bloco.&r"
		""
		"&7Trade-off:&r mais slots = menos capacidade por slot."
		""
		"&aIdeal pra organizar matéria-prima."
	]

	quest.7A00000000000022.title: "Functional Storage — Storage Controller"
	quest.7A00000000000022.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000022.quest_desc: [
		"&6O cérebro da rede de drawers.&r"
		""
		"O Storage Controller agrega TODOS os drawers num raio de 12 blocos. Você abre 1 GUI e vê tudo."
		""
		"&7Use a &eLinking Tool&r pra conectar drawers fora do raio."
	]

	quest.7A00000000000023.title: "Functional — Armory Cabinet"
	quest.7A00000000000023.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000023.quest_desc: [
		"&fArmazenamento de armas/armaduras.&r"
		""
		"Diferente dos drawers normais — Armory Cabinet aceita itens com NBT (encantados, com durabilidade, etc.)."
		""
		"&aRecompensa:&r endgame da árvore Functional Storage."
	]

	quest.7A00000000000030.title: "Iron Chests — Iron Chest"
	quest.7A00000000000030.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000030.quest_desc: [
		"&fO baú vanilla esticado.&r"
		""
		"Iron Chest tem &c54 slots&r (vs. 27 do baú normal)."
		""
		"&7Receita:&r 8 iron ingots + 1 chest."
	]

	quest.7A00000000000031.title: "Iron Chests — Gold Chest"
	quest.7A00000000000031.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000031.quest_desc: [
		"&6Gold Chest&r — &c81 slots&r (3 fileiras)."
		""
		"&aUpgrade simples: receita usa Gold Ingots em vez de Iron."
	]

	quest.7A00000000000032.title: "Iron Chests — Diamond Chest"
	quest.7A00000000000032.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000032.quest_desc: [
		"&bDiamond Chest&r — &c108 slots&r (4 fileiras)."
		""
		"&7Já é mais que um Shulker Box (27 slots) ou um baú duplo (54)."
	]

	quest.7A00000000000033.title: "Iron Chests — Obsidian Chest"
	quest.7A00000000000033.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000033.quest_desc: [
		"&5Obsidian Chest&r — &c108 slots + resistente a explosão&r."
		""
		"&aIdeal pra base perto de creepers/wither/etc."
	]

	quest.7A00000000000034.title: "Iron Chests — Crystal Chest"
	quest.7A00000000000034.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7A00000000000034.quest_desc: [
		"&bCrystal Chest&r — &c108 slots&r e &fmostra os itens dentro&r (visível por fora!)"
		""
		"&aIdeal pra display de itens, museu, decoração com função."
	]

	quest.7A00000000000040.title: "Backpack Básico"
	quest.7A00000000000040.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000040.quest_desc: [
		"&fLeve sua casa nas costas.&r"
		""
		"Sophisticated Backpack equipa no curio slot. Acessa o inventário sem ocupar slot da hotbar."
		""
		"&aDica:&r upgrades funcionam igual aos baús — magnet, pickup, smelting on-the-go."
	]

	quest.7A00000000000041.title: "Iron Backpack"
	quest.7A00000000000041.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000041.quest_desc: [
		"&fTier ferro pro mochileiro.&r"
		""
		"&aMais slots + 1 slot extra de upgrade."
	]

	quest.7A00000000000042.title: "Gold Backpack"
	quest.7A00000000000042.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000042.quest_desc: [
		"&6Tier ouro&r — capacidade considerável pra expedições longas."
	]

	quest.7A00000000000043.title: "Diamond Backpack"
	quest.7A00000000000043.quest_subtitle: "&fTier 2 — Vapor"
	quest.7A00000000000043.quest_desc: [
		"&bTier diamante&r — armazenamento sério no campo."
	]

	quest.7A00000000000044.title: "Netherite Backpack"
	quest.7A00000000000044.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7A00000000000044.quest_desc: [
		"&8Endgame portátil.&r"
		""
		"Resistente a fogo (não queima na lava). Máximo de slots."
		""
		"&aIdeal pra:&r minerar no Nether sem perder progresso por morte na lava."
	]

	quest.7A00000000000050.title: "Ender Chest (EnderStorage)"
	quest.7A00000000000050.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000050.quest_desc: [
		"&dArmazenamento link entre dimensões.&r"
		""
		"Diferente do Ender Chest vanilla, esse aceita &c3 cores de frequência&r — milhares de combinações possíveis."
		""
		"&aTodos os baús com a mesma combinação compartilham conteúdo."
	]

	quest.7A00000000000051.title: "Ender Pouch"
	quest.7A00000000000051.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000051.quest_desc: [
		"&fA versão portátil do Ender Chest.&r"
		""
		"Carregue no inventário. Acesse o Ender Chest de qualquer lugar."
		""
		"&aPerfeito para minerar — itens vão direto pra base via cor de frequência."
	]

	quest.7A00000000000052.title: "Ender Tank"
	quest.7A00000000000052.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000052.quest_desc: [
		"&bA versão fluida do Ender Chest.&r"
		""
		"Líquidos compartilhados por frequência. Útil pra centralizar lava, água, óleo."
	]

	quest.7A00000000000060.title: "Trash Cans (opcional)"
	quest.7A00000000000060.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000060.quest_desc: [
		"&7Para descartar o que não quer.&r"
		""
		"&fItem Trash Can&r — apaga itens"
		"&fFluid Trash Can&r — apaga fluidos"
		"&fEnergy Trash Can&r — drena energia (raro útil)"
		""
		"&aÚtil em automação:&r descartar overflow de Cobblestone Generator, etc."
	]

	quest.7A00000000000061.title: "Travelers Backpack (opcional)"
	quest.7A00000000000061.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7A00000000000061.quest_desc: [
		"&fAlternativa visual aos Sophisticated Backpacks.&r"
		""
		"Renderização do backpack nas costas (visível!). Aceita tanques de fluido integrados."
		""
		"&aEscolha estética + funcional."
	]

	quest.7A00000000FF00FF.title: "MESTRE DO ARMAZENAMENTO"
	quest.7A00000000FF00FF.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7A00000000FF00FF.quest_desc: [
		"&6&lDESAFIO COMPLETO&r"
		""
		"Complete o endgame de cada uma das 5 árvores principais:"
		""
		"&7• &fSophisticated Netherite Barrel&r"
		"&7• &fFunctional Armory Cabinet&r"
		"&7• &fIron Chests Crystal&r"
		"&7• &fNetherite Backpack&r"
		"&7• &fEnder Chest&r"
		""
		"&aVocê dominou a arte de guardar coisas. Próximo passo:&r digital storage (AE2 ou Refined Storage)."
		""
		"&7Recompensa: 16× Diamond + 500 XP."
	]

	# === MEKANISM ===
	quest.6A00000000000001.title: "Mekanism — A Indústria Química"
	quest.6A00000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.6A00000000000001.quest_desc: [
		"&6&lMEKANISM&r"
		""
		"O mod industrial mais clássico — herança direta de IC2/Tekkit. Tudo aqui é &cescalável&r: cada tier multiplica capacidade."
		""
		"&aTiers (do menor pro maior):&r"
		"&7• &fBasic&r — Steel + Osmium"
		"&7• &fAdvanced&r — Osmium Compressor"
		"&7• &eElite&r — Refined Glowstone"
		"&7• &dUltimate&r — Refined Obsidian"
		""
		"&aProcessamento de minério (o famoso 'macerator dobra'):&r"
		"&7• &fEnrichment&r → 1 ore = &c2 dust&r"
		"&7• &fPurification&r → 1 ore = &c3 dust&r (com oxygen)"
		"&7• &fInjection&r → 1 ore = &c4 dust&r (com hydrogen chloride)"
		"&7• &dDigital Miner&r — automine remoto"
		""
		"&7Endgame: Mekasuit + Fusion Reactor + Antimatter."
	]

	quest.6A00000000000002.title: "Steel Ingot"
	quest.6A00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.6A00000000000002.quest_desc: [
		"&fO metal-base do Mekanism.&r"
		""
		"&7Como obter:"
		"&7• 1 Iron Dust + Carbono no &eMetallurgic Infuser&r → Enriched Iron"
		"&7• Repete o processo → Steel Dust"
		"&7• Smelt → Steel Ingot"
		""
		"&aDica:&r carvão moído no Crusher = Carbon."
	]

	quest.6A00000000000003.title: "Steel Casing"
	quest.6A00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.6A00000000000003.quest_desc: [
		"&fO bloco-base de máquinas Mekanism.&r"
		""
		"&7Receita: 4 Steel Ingots + 4 Glass + 1 Osmium"
		""
		"&aSe você ativou a integração KubeJS, pode ser feito via Sequenced Assembly do Create!"
	]

	quest.6A00000000000004.title: "Metallurgic Infuser"
	quest.6A00000000000004.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A00000000000004.quest_desc: [
		"&aA primeira máquina do Mekanism.&r"
		""
		"Combina items + 'infuse types' (Carbono, Redstone, Diamond, Tin, etc.) pra fazer ligas e materiais novos."
		""
		"&7Útil pra:&r Steel, Bronze, Refined Obsidian (no tier alto)."
	]

	quest.6A00000000000005.title: "Heat Generator"
	quest.6A00000000000005.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A00000000000005.quest_desc: [
		"&cSua primeira fonte de energia.&r"
		""
		"Queima carvão, lenha ou lava (lava = MUITA energia)."
		""
		"&aDica:&r 1 lava bucket sobre o Heat Generator dura LOTES de tempo. Coloque um Electric Pump pra automatizar."
	]

	quest.6A00000000000006.title: "Enrichment Chamber"
	quest.6A00000000000006.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A00000000000006.quest_desc: [
		"&aA máquina mais importante do tier 1.&r"
		""
		"&7• 1 Iron Ore → 2 Iron Dust → 2 Iron Ingot (smelt)"
		"&7• Mesmo pra cobre, ouro, esmeralda, etc."
		""
		"&aIsso DOBRA seu minério.&r Vai pra tier mais alto pra triplicar/quadruplicar."
	]

	quest.6A00000000000007.title: "Basic Energy Cube"
	quest.6A00000000000007.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A00000000000007.quest_desc: [
		"&fO BatBox do Mekanism (estilo IC2!).&r"
		""
		"Armazena energia. Cada lado pode ser configurado como input ou output."
		""
		"&7Capacidade: ~4M FE."
	]

	quest.6A00000000000008.title: "Wind Generator"
	quest.6A00000000000008.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6A00000000000008.quest_desc: [
		"&aEnergia eólica.&r"
		""
		"Quanto mais alto (até Y=255), mais energia gera."
		""
		"&7Renovável. Sem combustível. Ótimo passive income."
	]

	quest.6A00000000000009.title: "Solar Generator"
	quest.6A00000000000009.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6A00000000000009.quest_desc: [
		"&eEnergia solar.&r"
		""
		"Funciona durante o dia. Build vários em paralelo pra escala."
		""
		"&aTier alto (Advanced Solar Generator) gera muito mais."
	]

	quest.6A0000000000000A.title: "Combiner"
	quest.6A0000000000000A.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A0000000000000A.quest_desc: [
		"&fDust → Ore.&r"
		""
		"O reverso do Enrichment Chamber. Combina dust + cobblestone = ore."
		""
		"&aÚtil em automação avançada (cycle de Cobblestone Generator)."
	]

	quest.6A0000000000000B.title: "Crusher"
	quest.6A0000000000000B.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A0000000000000B.quest_desc: [
		"&fIngot → Dust.&r"
		""
		"Quebra ingots de volta em pó (perde 1, ganha 1)."
		""
		"&aTambém faz: Bio Fuel, Carbon, Sulfur (pra reações químicas)."
	]

	quest.6A0000000000000C.title: "Energized Smelter"
	quest.6A0000000000000C.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6A0000000000000C.quest_desc: [
		"&aFurnace x8 — alimentado por energia.&r"
		""
		"Smelta itens em massa. Combina com Crusher + Enrichment Chamber pra processar minério inteiro automaticamente."
	]

	quest.6A0000000000000D.title: "Tier Advanced — Purification Chamber"
	quest.6A0000000000000D.quest_subtitle: "&bTier 3 — Elétrico"
	quest.6A0000000000000D.quest_desc: [
		"&6Tier 2 — Advanced.&r"
		""
		"&fPurification Chamber&r usa &eOxigênio&r (Electrolytic Separator) pra triplicar minério."
		""
		"&7Setup: água → Electrolytic Separator → Oxigênio + Hidrogênio → Purification Chamber"
		""
		"&aTriplica seu output. Vale o investimento."
	]

	quest.6A0000000000000E.title: "Tier Elite — Chemical Injection Chamber"
	quest.6A0000000000000E.quest_subtitle: "&dTier 4 — Avançado"
	quest.6A0000000000000E.quest_desc: [
		"&eTier 3 — Elite.&r"
		""
		"&fChemical Injection Chamber&r usa &eHydrogen Chloride&r (HCl) pra quadruplicar minério."
		""
		"&7Cadeia química: Water + Energy → H + O → H + Cl → HCl → Inject"
		""
		"&aEndgame de processamento. Sem perda."
	]

	quest.6A0000000000000F.title: "Tier Ultimate"
	quest.6A0000000000000F.quest_subtitle: "&dTier 4 — Avançado"
	quest.6A0000000000000F.quest_desc: [
		"&dTier 4 — Ultimate.&r"
		""
		"O ápice das máquinas Mekanism. Capacidade absurda, velocidade absurda."
		""
		"&7Materiais:&r"
		"&7• &fRefined Glowstone&r (tier elite)"
		"&7• &fRefined Obsidian&r (tier ultimate)"
		""
		"&aUltimate Energy Cube armazena bilhões de FE."
	]

	quest.6A00000000000010.title: "Digital Miner (opcional)"
	quest.6A00000000000010.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000010.quest_desc: [
		"&aMineração automatizada à distância.&r"
		""
		"Configure quais blocos minerar e o raio. O Digital Miner faz tudo sozinho — até dimensões inteiras."
		""
		"&cCustoso&r mas economiza horas de trabalho."
	]

	quest.6A00000000000011.title: "Mekanism Tools — Steel Paxel (opcional)"
	quest.6A00000000000011.quest_subtitle: "&fTier 2 — Vapor"
	quest.6A00000000000011.quest_desc: [
		"&fO 'paxel' do Mekanism.&r"
		""
		"Pickaxe + Axe + Shovel num item só. Steel é só o tier inicial — também tem Osmium, Refined Obsidian, etc."
		""
		"&aÚtil em mineração geral."
	]

	quest.6A00000000000012.title: "Mekasuit Helmet"
	quest.6A00000000000012.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000012.quest_desc: [
		"&dPart 1/4 da armadura tecnológica.&r"
		""
		"Aceita módulos: Night Vision, Solar Recharge, Auto-Eat, Vision Enhancement, etc."
	]

	quest.6A00000000000013.title: "Mekasuit Bodyarmor"
	quest.6A00000000000013.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000013.quest_desc: [
		"&dParte 2/4.&r"
		""
		"Módulos: Charge Distributor, Jetpack, Gravity Modulating, Radiation Shielding."
	]

	quest.6A00000000000014.title: "Mekasuit Pants"
	quest.6A00000000000014.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000014.quest_desc: [
		"&dParte 3/4.&r"
		""
		"Módulos: Mekasuit Pants Sprint, Step Assist, Locomotive Boosting."
	]

	quest.6A00000000000015.title: "Mekasuit Boots"
	quest.6A00000000000015.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000015.quest_desc: [
		"&dParte 4/4.&r"
		""
		"Módulos: Hydraulic Propulsion, Magnetic Attraction, Frost Walker."
		""
		"&aFull set + módulos = praticamente imortal."
	]

	quest.6A00000000000016.title: "Fission Reactor"
	quest.6A00000000000016.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000016.quest_desc: [
		"&cReator de fissão multibloco.&r"
		""
		"Construa a estrutura, alimente com Fissile Fuel (Uranium), gerencie temperatura com refrigerante."
		""
		"&cAtenção:&r superaquecimento causa MELTDOWN — radiação destruidora."
		""
		"&aGera enormes quantidades de calor → use Heat Generators ou Boilers + Turbines pra converter em FE."
	]

	quest.6A00000000000017.title: "Fusion Reactor"
	quest.6A00000000000017.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000017.quest_desc: [
		"&eReator de fusão multibloco.&r"
		""
		"Funde Deuterium + Tritium → Hélio + ENERGIA."
		""
		"&7Setup avançado, requer Mekanism endgame, mas é a fonte mais densa de energia do mod."
		""
		"&aSem radiação. Sem meltdown. Mas precisa de hohlraum + laser pra acender."
	]

	quest.6A0000000000FFFF.title: "ANTIMATÉRIA"
	quest.6A0000000000FFFF.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A0000000000FFFF.quest_desc: [
		"&6&lO PONTO MAIS ALTO DO MEKANISM&r"
		""
		"Antimatter Pellets são produzidos por &eAntimatter Organizer&r — máquina endgame que requer tier Ultimate + energia massiva."
		""
		"Cada pellet armazena energia equivalente a uma estrela."
		""
		"&aRecompensa:&r 4× Antimatter Pellet + Netherite Block + 1500 XP."
		""
		"&7Você dominou a indústria química. Agora pode olhar pra: Powah Endgame, AE2 Quantum, ou Mekasuit completo."
	]

	# === AE2 ===
	quest.641F3E023D95DF84.title: "Applied Energistics 2"
	quest.641F3E023D95DF84.quest_subtitle: "&8Tier 0 — Despertar"
	quest.641F3E023D95DF84.quest_desc: [
		"&6&lAPPLIED ENERGISTICS 2&r"
		""
		"O sistema de armazenamento &fmais poderoso&r do Minecraft modado. AE2 não é só baú — é uma &cREDE&r."
		""
		"&aFundamentos:&r"
		"&7• &fCertus Quartz&r — recurso base"
		"&7• &fFluix Crystal&r — energia da rede"
		"&7• &fProcessadores&r — Logic / Calculation / Engineering"
		"&7• &fME Drive + Storage Cells&r — armazena tudo"
		"&7• &fCrafting Terminal&r — interface"
		"&7• &fPattern Provider + Molecular Assembler&r — auto-craft"
		""
		"&aEndgame:&r"
		"&7• &fME Controller&r (multiblock)"
		"&7• &fQuantum Network Bridge&r (long-distance)"
		"&7• &fSpatial Storage&r (salva regiões inteiras)"
		"&7• &fWireless Terminal&r (acesso remoto)"
		""
		"&7Comparação: &eRefined Storage&r é mais simples, &fAE2&r é mais técnico mas infinitamente mais poderoso."
	]

	quest.1BE7EDCB9289FBA3.title: "Certus Quartz Crystal"
	quest.1BE7EDCB9289FBA3.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1BE7EDCB9289FBA3.quest_desc: [
		"&fO recurso base de tudo no AE2.&r"
		""
		"&7Como obter:"
		"&7• Mine &eCertus Quartz Ore&r (overworld, parecido com nether quartz)"
		"&7• Cultive &fSeed Certus&r em água com Charged Certus pra acelerar"
	]

	quest.AE00000000000003.title: "Quartz Grindstone"
	quest.AE00000000000003.quest_desc: [
		"&fProcessamento sem energia.&r"
		""
		"O Grindstone moe minérios manualmente — não precisa de eletricidade. Útil pra processar Certus, Fluix, ferro, ouro nos primeiros tempos."
		""
		"&aDica:&r dobra alguns minérios sem precisar de Mekanism."
	]

	quest.4DCDA0631552788D.title: "Charger"
	quest.4DCDA0631552788D.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4DCDA0631552788D.quest_desc: [
		"&aA primeira máquina elétrica AE2.&r"
		""
		"Recebe energia (FE) e &ecarrega&r:"
		"&7• Certus Quartz Crystal → Charged Certus"
		"&7• Itens AE2 (drives, terminals, etc.)"
		""
		"&7Receita: precisa de Wood + Iron + Quartz."
	]

	quest.48FABA44E2E46BC9.title: "Charged Certus Quartz"
	quest.48FABA44E2E46BC9.quest_subtitle: "&7Tier 1 — Bronze"
	quest.48FABA44E2E46BC9.quest_desc: [
		"&eVersão energizada do Certus.&r"
		""
		"Necessário pra fazer Fluix Crystals e processadores."
		""
		"&aDica:&r joga Certus Crystal num cubo de água com Redstone + Nether Quartz e bate raio = Fluix natural."
	]

	quest.4CC5B944C6914F30.title: "Fluix Crystal"
	quest.4CC5B944C6914F30.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4CC5B944C6914F30.quest_desc: [
		"&dO 'sangue' da rede AE2.&r"
		""
		"Faz cabos, processadores, conduits. Tudo na rede precisa de Fluix."
		""
		"&7Receita Charger:&r 1 Charged Certus + 1 Nether Quartz + 1 Redstone (em água!) = Fluix Dust → crystal"
	]

	quest.6668E5668026E79F.title: "Inscriber"
	quest.6668E5668026E79F.quest_subtitle: "&fTier 2 — Vapor"
	quest.6668E5668026E79F.quest_desc: [
		"&fA máquina que faz processadores.&r"
		""
		"Recebe placas (presses) + materiais e produz processadores. Cada tipo de processador exige uma press específica."
		""
		"&7As 4 presses (rare drops do Meteorite):&r"
		"&7• Logic Press"
		"&7• Calculation Press"
		"&7• Engineering Press"
		"&7• Silicon Press"
	]

	quest.743E9A73D95106C2.title: "Logic Processor"
	quest.743E9A73D95106C2.quest_subtitle: "&fTier 2 — Vapor"
	quest.743E9A73D95106C2.quest_desc: [
		"&eProcessador básico.&r"
		""
		"Feito com Logic Press + Gold + Silicon."
		""
		"&7Usado em: cabos, drives, storage cells básicos."
	]

	quest.7E5DBC8DF5DD7AD3.title: "Calculation Processor"
	quest.7E5DBC8DF5DD7AD3.quest_subtitle: "&fTier 2 — Vapor"
	quest.7E5DBC8DF5DD7AD3.quest_desc: [
		"&bProcessador médio.&r"
		""
		"Calc Press + Pure Certus + Silicon."
		""
		"&7Usado em: terminals, formation core, etc."
	]

	quest.0924E2E175977EE0.title: "Engineering Processor"
	quest.0924E2E175977EE0.quest_subtitle: "&fTier 2 — Vapor"
	quest.0924E2E175977EE0.quest_desc: [
		"&dProcessador avançado.&r"
		""
		"Eng Press + Diamond + Silicon."
		""
		"&7Usado em: Pattern Provider, Molecular Assembler, ME Controller."
	]

	quest.7DDEE9922772D9FB.title: "ME Cable"
	quest.7DDEE9922772D9FB.quest_subtitle: "&bTier 3 — Elétrico"
	quest.7DDEE9922772D9FB.quest_desc: [
		"&fA espinha dorsal da rede.&r"
		""
		"Conecta máquinas, terminais, drives. Cada bloco precisa estar conectado."
		""
		"&7Tipos:&r Glass Cable (1 channel), Smart Cable (mostra channels), Dense Cable (32 channels)."
	]

	quest.44E9467176A27D12.title: "ME Drive"
	quest.44E9467176A27D12.quest_subtitle: "&bTier 3 — Elétrico"
	quest.44E9467176A27D12.quest_desc: [
		"&aA caixa que segura suas Storage Cells.&r"
		""
		"Cada Drive aceita 10 cells. Você plugga num cabo da rede e tudo dentro vira parte do storage."
	]

	quest.4A3C9C57C5EC0E42.title: "Storage Cells (1k e 4k)"
	quest.4A3C9C57C5EC0E42.quest_subtitle: "&dTier 4 — Avançado"
	quest.4A3C9C57C5EC0E42.quest_desc: [
		"&aOs primeiros tiers de armazenamento.&r"
		""
		"&7• 1k = 8.192 itens (até 63 tipos)"
		"&7• 4k = 32.768 itens (até 63 tipos)"
		""
		"&aTrade-off:&r quanto mais &etipos diferentes&r de itens, menos &fitens totais&r."
	]

	quest.7B22BAD746F0AEC7.title: "Storage Cells (16k e 64k)"
	quest.7B22BAD746F0AEC7.quest_subtitle: "&dTier 4 — Avançado"
	quest.7B22BAD746F0AEC7.quest_desc: [
		"&aTiers altos de armazenamento.&r"
		""
		"&7• 16k = 131.072 itens"
		"&7• 64k = 524.288 itens (até 63 tipos)"
		""
		"&aFinalmente storage 'infinito' pra prática.&r"
	]

	quest.006F15254558CF88.title: "Crafting Terminal"
	quest.006F15254558CF88.quest_subtitle: "&dTier 4 — Avançado"
	quest.006F15254558CF88.quest_desc: [
		"&aA tela principal da rede.&r"
		""
		"Acessa todo storage, mostra quantidades, permite crafting com itens da rede direto na grade 3x3."
		""
		"&7Existe versão wireless via &fAE2WTLib&r — acesso remoto à rede."
	]

	quest.7557248DBF779A48.title: "Pattern Provider"
	quest.7557248DBF779A48.quest_subtitle: "&dTier 4 — Avançado"
	quest.7557248DBF779A48.quest_desc: [
		"&6O coração do auto-craft.&r"
		""
		"Encoda padrões (patterns) com Pattern Encoder e bota no Pattern Provider. Quando a rede precisar craftar, ele envia os ingredientes."
		""
		"&7Direciona para:&r Molecular Assembler (crafting normal) ou máquinas externas (smelter, mixer, etc.)."
	]

	quest.71A7FC46115C33CA.title: "Molecular Assembler"
	quest.71A7FC46115C33CA.quest_subtitle: "&6Tier 5 — Endgame"
	quest.71A7FC46115C33CA.quest_desc: [
		"&aO 'crafter' invisível.&r"
		""
		"Junto com Pattern Provider, faz crafting 3x3 automatizado. Cada pattern precisa de um pair Provider + Assembler."
		""
		"&aCom isso, sua rede crafta &eQUALQUER&r receita 3x3 sem você."
	]

	quest.1779AC7F2F843F52.title: "Crafting CPU (Multiblock)"
	quest.1779AC7F2F843F52.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1779AC7F2F843F52.quest_desc: [
		"&fA CPU que orquestra crafting massivo.&r"
		""
		"Multiblock que combina:"
		"&7• &fCrafting Storage&r (cells dedicados pra crafting)"
		"&7• &fCrafting Co-Processing Unit&r (várias receitas em paralelo)"
		"&7• &fCrafting Accelerator&r (mais rápido)"
		""
		"&aSetup grande = pode craftar receitas com 1000+ ingredientes em segundos."
	]

	quest.33CDC38D778D8B25.title: "Energy Acceptor"
	quest.33CDC38D778D8B25.quest_subtitle: "&bTier 3 — Elétrico"
	quest.33CDC38D778D8B25.quest_desc: [
		"&aA porta de energia da rede.&r"
		""
		"Aceita FE (de Mekanism, IE, Powah, etc.) e converte em AE — a moeda interna da rede."
		""
		"&7Importante:&r AE2 NÃO consome muito FE no idle, mas durante crafting pode picar bastante."
	]

	quest.058EDD16A14C8D7F.title: "ME Controller"
	quest.058EDD16A14C8D7F.quest_subtitle: "&6Tier 5 — Endgame"
	quest.058EDD16A14C8D7F.quest_desc: [
		"&aO multiblock central de redes complexas.&r"
		""
		"Sem Controller: 8 channels max."
		"Com Controller: 32 channels por face × 6 faces = MUITAS conexões."
		""
		"&7Você precisa quando:&r"
		"&7• Vários auto-crafts em paralelo"
		"&7• Wireless terminals"
		"&7• Quantum Link"
	]

	quest.AE00000000000015.title: "Wireless Terminal (opcional)"
	quest.AE00000000000015.quest_desc: [
		"&aAcesse a rede de qualquer lugar.&r"
		""
		"Carregue na hotbar, segure direito = abre o Crafting Terminal remoto."
		""
		"&7Booster cards aumentam o range. Útil pra mineração — joga itens direto na rede."
	]

	quest.192057704C88C1DB.title: "Quantum Link (opcional)"
	quest.192057704C88C1DB.quest_subtitle: "&6Tier 5 — Endgame"
	quest.192057704C88C1DB.quest_desc: [
		"&dRedes conectadas por dimensão.&r"
		""
		"2 Quantum Rings com Singularity entangled = canal entre 2 redes em qualquer distância."
		""
		"&aÚtil pra:&r outpost mining, base no Nether/End conectada à overworld."
	]

	quest.75385DF32C07BFFA.title: "Spatial Storage (opcional)"
	quest.75385DF32C07BFFA.quest_subtitle: "&6Tier 5 — Endgame"
	quest.75385DF32C07BFFA.quest_desc: [
		"&dArmazene REGIÕES INTEIRAS.&r"
		""
		"Spatial Cells salvam um cubo do mundo (entidades, blocos, tudo). Use Spatial Pylon pra construir uma 'sala de transferência'."
		""
		"&aIdeal pra:&r mover bases inteiras, transportar reatores ativos, etc."
	]

	quest.728B7BBFA83DC144.title: "REDE TOTAL"
	quest.728B7BBFA83DC144.quest_subtitle: "&6Tier 5 — Endgame"
	quest.728B7BBFA83DC144.quest_desc: [
		"&6&lDOMÍNIO COMPLETO DA REDE&r"
		""
		"Você construiu a rede definitiva. Tudo automatizado, tudo conectado, tudo otimizado."
		""
		"&7Recompensa:&r 8× ME 256k Cell + Netherite Block + 1000 XP."
		""
		"&aPróximo passo:&r combine com Mekasuit + Wireless Terminal + Reator Mekanism = endgame de verdade."
	]

	# === REFINED STORAGE ===
	quest.3738F893D1D748A7.title: "Refined Storage — A alternativa simples"
	quest.3738F893D1D748A7.quest_subtitle: "&8Tier 0 — Despertar"
	quest.3738F893D1D748A7.quest_desc: [
		"&6&lREFINED STORAGE&r"
		""
		"Inspirado no AE2, mas &asem complicação&r:"
		"&7• Sem channels"
		"&7• Sem Pattern Encoder separado"
		"&7• Tudo configurável diretamente"
		""
		"&aCompare:&r"
		"&7• &eAE2&r — mais técnico, channels, Quantum Network, Spatial"
		"&7• &fRS&r — plug-and-play, fácil de escalar, ótimo pra iniciantes"
		""
		"&7Você pode usar &fos dois&r juntos! Mekanism Integration permite RS armazenar fluidos/gases."
	]

	quest.77CFC60C7505BBC9.title: "Quartz Enriched Iron"
	quest.77CFC60C7505BBC9.quest_subtitle: "&7Tier 1 — Bronze"
	quest.77CFC60C7505BBC9.quest_desc: [
		"&fO ingrediente base de RS.&r"
		""
		"&7Receita:&r 4 Iron + 4 Quartz (em forma de cruz)."
	]

	quest.2CD8C78DD826C596.title: "Processor Binding"
	quest.2CD8C78DD826C596.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2CD8C78DD826C596.quest_desc: [
		"&fO 'cabo flexível' dos processadores.&r"
		""
		"Componente comum em quase todos os processors."
	]

	quest.168C02B34D82AB84.title: "Processadores RS"
	quest.168C02B34D82AB84.quest_subtitle: "&fTier 2 — Vapor"
	quest.168C02B34D82AB84.quest_desc: [
		"&aOs 3 tiers de processador.&r"
		""
		"&7• &fBasic Processor&r — itens iniciais"
		"&7• &fImproved Processor&r — Disk Drive, controllers"
		"&7• &eAdvanced Processor&r — Auto-crafter, Wireless Grid"
	]

	quest.1CE7B69DE6BFC5A4.title: "RS Controller"
	quest.1CE7B69DE6BFC5A4.quest_subtitle: "&fTier 2 — Vapor"
	quest.1CE7B69DE6BFC5A4.quest_desc: [
		"&aO bloco central da rede.&r"
		""
		"Aceita energia (FE), distribui pra todos os componentes via cable. Comparado ao AE2 Controller — RS é &emuito mais simples&r."
		""
		"&7Apenas 1 Controller por rede. Pluggable lateralmente em cabos."
	]

	quest.0F77E2146DD31D74.title: "Cabo RS"
	quest.0F77E2146DD31D74.quest_subtitle: "&fTier 2 — Vapor"
	quest.0F77E2146DD31D74.quest_desc: [
		"&fConecta tudo.&r"
		""
		"Cabos RS são mais simples que AE2 — sem channels, sem dense cable. Só plugue."
	]

	quest.294E69DF1FF67A3B.title: "Disk Drive"
	quest.294E69DF1FF67A3B.quest_subtitle: "&bTier 3 — Elétrico"
	quest.294E69DF1FF67A3B.quest_desc: [
		"&fA caixa que segura os disks.&r"
		""
		"8 slots, cada slot aceita 1 storage disk. Conecte ao cable da rede."
	]

	quest.34A46D14BE540CD8.title: "Storage Disks 1k → 16k"
	quest.34A46D14BE540CD8.quest_subtitle: "&bTier 3 — Elétrico"
	quest.34A46D14BE540CD8.quest_desc: [
		"&aTiers iniciais e médios.&r"
		""
		"&7• 1k = 1.000 itens"
		"&7• 4k = 4.000 itens"
		"&7• 16k = 16.000 itens"
		""
		"&aMais simples que AE2 — quantidades absolutas, sem trade-off de tipos."
	]

	quest.1220E483A0FE72EF.title: "Storage Disk 64k"
	quest.1220E483A0FE72EF.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1220E483A0FE72EF.quest_desc: [
		"&aTier alto.&r"
		""
		"64.000 itens por disk. Acima disso só Mekanism Integration ou modpacks específicos."
	]

	quest.0A097520B65D2566.title: "Crafting Grid"
	quest.0A097520B65D2566.quest_subtitle: "&fTier 2 — Vapor"
	quest.0A097520B65D2566.quest_desc: [
		"&aA interface principal.&r"
		""
		"Crafta com itens da rede, mostra todo storage. Equivalente ao Crafting Terminal do AE2."
	]

	quest.2104B081E07F547F.title: "Pattern Grid"
	quest.2104B081E07F547F.quest_subtitle: "&bTier 3 — Elétrico"
	quest.2104B081E07F547F.quest_desc: [
		"&aOnde você cria patterns.&r"
		""
		"Crafte itens 'fictícios' aqui pra criar patterns que vão pro Auto-crafter."
		""
		"&aMais simples que AE2 — sem máquina dedicada de encoding."
	]

	quest.46DFA1BF679293DC.title: "Auto-crafter"
	quest.46DFA1BF679293DC.quest_subtitle: "&dTier 4 — Avançado"
	quest.46DFA1BF679293DC.quest_desc: [
		"&aO equivalente ao Pattern Provider + Molecular Assembler do AE2 num único bloco.&r"
		""
		"Insira patterns. Quando a rede precisar do item resultado, ele crafta sozinho."
		""
		"&7Coloque vários em paralelo pra escala."
	]

	quest.078BA854AD66829C.title: "Wireless Grid (opcional)"
	quest.078BA854AD66829C.quest_subtitle: "&fTier 2 — Vapor"
	quest.078BA854AD66829C.quest_desc: [
		"&aAcesso remoto à rede.&r"
		""
		"Carregue na hotbar, segure direito = abre o Crafting Grid remoto. Excelente pra mineração."
	]

	quest.5C20779BAA2FA0AC.title: "External Storage (opcional)"
	quest.5C20779BAA2FA0AC.quest_subtitle: "&fTier 2 — Vapor"
	quest.5C20779BAA2FA0AC.quest_desc: [
		"&fIntegre baús externos como storage.&r"
		""
		"External Storage tratam outros containers (chest, drawer, AE2, etc.) como parte do RS storage."
		""
		"&aÚtil pra:&r mover gradualmente de baús pra rede."
	]

	quest.4C8FD63F492742C5.title: "REDE RS COMPLETA"
	quest.4C8FD63F492742C5.quest_subtitle: "&dTier 4 — Avançado"
	quest.4C8FD63F492742C5.quest_desc: [
		"&6&lDOMÍNIO DA REDE SIMPLES&r"
		""
		"Você fez uma rede completa com auto-craft + wireless. Tudo organizado, tudo automatizado."
		""
		"&7Recompensa:&r 4× 1024k Storage Disk + 800 XP."
		""
		"&aOpcional avançado:&r combine com &eRefined Storage Mekanism Integration&r pra armazenar gases químicos do Mek!"
	]

	# === IMMERSIVE ENGINEERING ===
	quest.1E00000000000001.title: "Immersive Engineering"
	quest.1E00000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.1E00000000000001.quest_desc: [
		"&6&lIMMERSIVE ENGINEERING&r"
		""
		"O mod tech &cmais estético&r — máquinas grandes, multiblocks impressionantes, vibe de revolução industrial."
		""
		"&aProgressão estilo IC2 com 3 voltagens:&r"
		"&7• &eLV (Low Voltage)&r — 256 RF/t máx por wire"
		"&7• &6MV (Medium Voltage)&r — 1024 RF/t"
		"&7• &cHV (High Voltage)&r — 4096 RF/t"
		""
		"&aMultiblocks notáveis:&r"
		"&7• &fCoke Oven&r → Coal Coke + Creosote"
		"&7• &fBlast Furnace&r → Steel"
		"&7• &fExcavator&r → mineração massiva"
		"&7• &fGarden Cloche&r → farming auto"
		""
		"&7Ferramentas: &fEngineer's Hammer&r e &fWire Cutter&r — você vai usar muito."
	]

	quest.1E00000000000002.title: "Hammer e Wire Cutter"
	quest.1E00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000002.quest_desc: [
		"&fAs ferramentas básicas do engenheiro.&r"
		""
		"&fHammer&r — usado pra rotacionar blocos, montar wire connectors, processar matérias-primas em algumas receitas."
		""
		"&fWire Cutter&r — corta wire connections."
	]

	quest.1E00000000000003.title: "Coke Oven Bricks"
	quest.1E00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000003.quest_desc: [
		"&fOs tijolos do Coke Oven.&r"
		""
		"Coke Oven é um multiblock 3x3x3. Construa com 27 Coke Oven Bricks + Engineer's Hammer."
		""
		"&aProduz Coal Coke (queima 2x mais que carvão) e Creosote Oil (combustível pra Diesel)."
	]

	quest.1E00000000000004.title: "Coal Coke + Creosote"
	quest.1E00000000000004.quest_subtitle: "&fTier 2 — Vapor"
	quest.1E00000000000004.quest_desc: [
		"&aOs primeiros produtos do Coke Oven.&r"
		""
		"Joga carvão dentro, sai &fCoal Coke&r (forte). Subproduto: &eCreosote Oil&r."
		""
		"&7Coal Coke é necessário pro Blast Furnace fazer Steel."
	]

	quest.1E00000000000005.title: "Blast Furnace Bricks"
	quest.1E00000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000005.quest_desc: [
		"&fOs tijolos do Blast Furnace.&r"
		""
		"Multiblock 3x3x3 (similar ao Coke Oven). Construa pra produzir Steel."
		""
		"&7Receita: Iron Ingot + Coal Coke = Steel Ingot."
	]

	quest.1E00000000000006.title: "Steel Ingot"
	quest.1E00000000000006.quest_subtitle: "&fTier 2 — Vapor"
	quest.1E00000000000006.quest_desc: [
		"&fO Steel do IE.&r"
		""
		"Diferente do Steel do Mekanism (mas mesma tag &c#c:ingots/steel&r). AlmostUnified resolve a duplicação."
		""
		"&aDesbloqueia:&r máquinas tier 2, scaffolding, multiblocks avançados."
	]

	quest.1E00000000000007.title: "Windmill"
	quest.1E00000000000007.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1E00000000000007.quest_desc: [
		"&aEnergia eólica clássica.&r"
		""
		"Coloque alto (Y > 100). Transmite kinetic energy via Wooden Post pra um Kinetic Dynamo."
		""
		"&7Vibe steampunk pura. Útil + decorativo."
	]

	quest.1E00000000000008.title: "Kinetic Dynamo"
	quest.1E00000000000008.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1E00000000000008.quest_desc: [
		"&aConverte rotação em FE.&r"
		""
		"Recebe rotação de Windmill ou Watermill. Output: LV (256 RF/t)."
		""
		"&7Sua primeira fonte de eletricidade."
	]

	quest.1E00000000000009.title: "Thermoelectric Generator"
	quest.1E00000000000009.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1E00000000000009.quest_desc: [
		"&aEnergia termal (calor + frio).&r"
		""
		"Cerque com bloco quente (Lava) E frio (Gelo / Water). Quanto maior a diferença = mais energia."
		""
		"&7Setup esperto: 4 lados de lava + 4 lados de packed ice = MUITA energia."
	]

	quest.1E0000000000000A.title: "LV — Low Voltage"
	quest.1E0000000000000A.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1E0000000000000A.quest_desc: [
		"&eO primeiro tier de eletricidade.&r"
		""
		"&fWire Coil LV&r — fios"
		"&fLV Connector&r — pluga em máquinas/dynamos"
		"&fLV Capacitor&r — armazena 100k FE"
		""
		"&7Limite: 256 RF/t por wire. Suficiente pro early-game."
	]

	quest.1E0000000000000B.title: "MV — Medium Voltage"
	quest.1E0000000000000B.quest_subtitle: "&dTier 4 — Avançado"
	quest.1E0000000000000B.quest_desc: [
		"&6O segundo tier.&r"
		""
		"&fMV Wire&r — 1024 RF/t"
		"&fMV Capacitor&r — 1M FE"
		""
		"&aPrecisa de Steel. Tier ideal pra automação séria."
	]

	quest.1E0000000000000C.title: "HV — High Voltage"
	quest.1E0000000000000C.quest_subtitle: "&dTier 4 — Avançado"
	quest.1E0000000000000C.quest_desc: [
		"&cTier máximo do IE.&r"
		""
		"&fHV Wire&r — 4096 RF/t"
		"&fHV Capacitor&r — 4M FE"
		""
		"&aPrecisa de Aluminum + Steel. Tier endgame."
	]

	quest.1E0000000000000D.title: "Garden Cloche"
	quest.1E0000000000000D.quest_subtitle: "&bTier 3 — Elétrico"
	quest.1E0000000000000D.quest_desc: [
		"&aFarming dentro de uma cúpula de vidro.&r"
		""
		"Coloca uma seed no slot, água no tank, terra/areia/etc no slot inferior. Cresce continuamente."
		""
		"&7Funciona com:&r trigo, beterraba, cactus, melancia, e até flores."
		""
		"&aDica:&r combina lindo com Mystical Agriculture seeds!"
	]

	quest.1E0000000000000E.title: "Steel Scaffolding"
	quest.1E0000000000000E.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E0000000000000E.quest_desc: [
		"&fA estrutura visual do IE.&r"
		""
		"Usado em multiblocks decorativos e funcionais. Vibe de revolução industrial pura."
		""
		"&aBase para:&r Excavator, Diesel Generator, Crusher (multiblocks endgame)."
	]

	quest.1E0000000000000F.title: "Diesel Generator (opcional)"
	quest.1E0000000000000F.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E0000000000000F.quest_desc: [
		"&cMultiblock de combustão.&r"
		""
		"Queima Diesel (refinado de Petróleo via Refinery) ou Creosote Oil. Output massivo."
		""
		"&aGera 4096 RF/t — alimenta facilmente uma fábrica inteira em HV."
	]

	quest.1E00000000FFFFFF.title: "INDÚSTRIA IMERSIVA"
	quest.1E00000000FFFFFF.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E00000000FFFFFF.quest_desc: [
		"&6&lIE COMPLETO&r"
		""
		"Você dominou o Immersive Engineering. Coke Oven, Blast Furnace, multiblocks, e HV ativo."
		""
		"&aRecompensa:&r 16× Steel + Netherite Ingot + 1000 XP."
		""
		"&7Próximo passo:&r Excavator + Diesel Generator pra mineração industrial massiva."
	]

	# === POWAH ===
	quest.03A583E64FAE229F.title: "Powah — A Era da Energia"
	quest.03A583E64FAE229F.quest_subtitle: "&8Tier 0 — Despertar"
