	quest.9600000000000004.title: "Cannonball e Saltpeter"
	quest.9600000000000004.quest_desc: [
		"&aMunição.&r"
		""
		"Cannonball = projétil. Saltpeter = combustível. Carregue antes de disparar."
	]

	quest.9600000000000005.title: "Autocannon Barrel"
	quest.9600000000000005.quest_desc: [
		"&cTier 2 — disparo rápido.&r"
		""
		"Auto-disparo via redstone. Ideal pra defesa de base."
	]

	quest.3B8D93AD0CC7439F.title: "Cannon Loader (opcional)"
	quest.3B8D93AD0CC7439F.quest_subtitle: "&fTier 2 — Vapor"
	quest.3B8D93AD0CC7439F.quest_desc: [
		"&aRecarga automática.&r"
		""
		"Conecte um chest com cannonball + saltpeter. O loader recarrega o canhão sem você precisar."
	]

	quest.960000000000FFFF.title: "ARTILHEIRO"
	quest.960000000000FFFF.quest_desc: [
		"&6&lDISPARO COMPLETO&r"
		""
		"Você montou e disparou um Big Cannon. Os céus tremem."
