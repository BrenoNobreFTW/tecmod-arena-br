	# === ORITECH ===
	quest.0200000000000001.title: "Oritech — Tech Modular"
	quest.0200000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.0200000000000001.quest_desc: [
		"&6&lORITECH&r"
		""
		"Mod tech &amoderno&r e &cclean&r — interface elegante, máquinas modulares, expansões via upgrades."
		""
		"&aMáquinas core:&r"
		"&7• &fPulverizer&r — moedor (1 ore = 2 dust)"
		"&7• &fFoundry&r — fundição"
		"&7• &fAssembler&r — auto-craft"
		"&7• &fAtomic Forge&r — endgame, materiais raros"
		""
		"&aDiferenciais:&r"
		"&7• Speed/Capacity upgrades"
		"&7• Multi-tier modular"
		"&7• Solar panel scaling"
		"&7• Visual moderno (não imitando IC2/Mekanism)"
	]

	quest.0200000000000002.title: "Machine Frame"
	quest.0200000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.0200000000000002.quest_desc: [
		"&fO frame base de toda máquina Oritech.&r"
		""
		"Receita: Iron + Glass + outros materiais."
		""
		"&7Reutilizado em todas as máquinas — economiza recursos no longo prazo."
	]

	quest.0200000000000003.title: "Pulverizer"
	quest.0200000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.0200000000000003.quest_desc: [
		"&fO macerator do Oritech.&r"
		""
		"1 minério = 2 pó. Aceita upgrades de speed (acelera) e capacity (mais slots de output)."
		""
		"&aTier inicial — base de processamento."
	]

	quest.0200000000000004.title: "Foundry"
	quest.0200000000000004.quest_subtitle: "&7Tier 1 — Bronze"
	quest.0200000000000004.quest_desc: [
		"&aFundição moderna.&r"
		""
		"Smelta minérios e ligas. Mais rápido que Furnace vanilla. Aceita upgrades."
		""
		"&7Output: ingots de tier 1."
	]

	quest.0200000000000005.title: "Assembler"
	quest.0200000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.0200000000000005.quest_desc: [
		"&fAuto-crafter Oritech.&r"
		""
		"Configure receita uma vez, ele crafta em loop. Útil pra circuitos e peças intermediárias."
	]

	quest.0200000000000006.title: "Battery e Storage"
	quest.0200000000000006.quest_subtitle: "&fTier 2 — Vapor"
	quest.0200000000000006.quest_desc: [
		"&aArmazenamento Oritech.&r"
		""
		"&fBasic Battery&r — portátil"
		"&fSmall Storage Block&r — fixed, escalável"
		""
		"&7Combine com Solar Panel pra base auto-sustentável."
	]

	quest.0200000000000007.title: "Solar Panel"
	quest.0200000000000007.quest_subtitle: "&fTier 2 — Vapor"
	quest.0200000000000007.quest_desc: [
		"&eEnergia limpa.&r"
		""
		"Tier inicial. Tier alto disponível depois (fragments)."
		""
		"&aDica:&r empilhe vários no telhado."
	]

	quest.0200000000000008.title: "Fragment Forge"
	quest.0200000000000008.quest_subtitle: "&fTier 2 — Vapor"
	quest.0200000000000008.quest_desc: [
		"&aForja de fragmentos especiais.&r"
		""
		"Cria componentes únicos do Oritech (Adamant Fragments, etc.)."
		""
		"&7Necessária pra progredir pro Atomic Forge."
	]

	quest.0200000000000009.title: "Atomic Forge"
	quest.0200000000000009.quest_subtitle: "&fTier 2 — Vapor"
	quest.0200000000000009.quest_desc: [
		"&dForja atômica.&r"
		""
		"Combina fragmentos em itens endgame. Materiais lendários como Adamant."
		""
		"&aÁpice da progressão Oritech."
	]

	quest.020000000000000A.title: "Laser Arm (opcional)"
	quest.020000000000000A.quest_subtitle: "&fTier 2 — Vapor"
	quest.020000000000000A.quest_desc: [
		"&cBraço laser para mineração ou ataque.&r"
		""
		"Configurável — pode minerar blocos a distância ou atacar mobs."
		""
		"&7Visual moderno, alta precisão."
	]

	quest.020000000000FFFF.title: "ORITECH COMPLETO"
	quest.020000000000FFFF.quest_subtitle: "&fTier 2 — Vapor"
	quest.020000000000FFFF.quest_desc: [
		"&6&lDOMÍNIO MODULAR&r"
		""
		"Você construiu a indústria moderna. Atomic Forge ativa, fragmentos sendo forjados."
		""
