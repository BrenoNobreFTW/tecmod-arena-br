	# === ENIGMATIC LEGACY ===
	quest.36C424AEE3C19C7C.title: "Enigmatic Legacy — As 7 Maldições"
	quest.36C424AEE3C19C7C.quest_subtitle: "&8Tier 0 — Despertar"
	quest.36C424AEE3C19C7C.quest_desc: [
		"&6&lENIGMATIC LEGACY PLUS&r"
		""
		"Mod centrado em &cmaldições&r e &eitens cursed&r — buffs poderosos com custos terríveis."
		""
		"&aPilar do mod: o Anel das 7 Maldições.&r Aceitar = ganhar +loot/dano/XP. Mas você sofre:"
		"&7• Insônia (phantoms)"
		"&7• Mais dano de monstros"
		"&7• Armor reduzido"
		"&7• Eternal burning"
		"&7• Soul Crystals (perde alma ao morrer)"
		""
		"&7No nosso pack: morrer com o anel = perde 1 coração permanente até regenerar."
	]
	quest.4FCE8435F34C1EB3.title: "Cursed Ring"
	quest.4FCE8435F34C1EB3.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4FCE8435F34C1EB3.quest_desc: ["&5O início. Equipe e aceite as 7 maldições. Volta atrás é &cdifícil&r."]
	quest.780784F2A7E51158.title: "Soul Crystal"
	quest.780784F2A7E51158.quest_subtitle: "&7Tier 1 — Bronze"
	quest.780784F2A7E51158.quest_desc: ["&dRecupere almas perdidas. 1 alma = 1 coração de volta."]
	quest.C500000000000004.title: "Heart of Creation"
	quest.C500000000000004.quest_desc: ["&cRegenera 1 coração permanente. Drop raro de bosses."]
	quest.7C51F8586CF77300.title: "Berserk Emblem"
	quest.7C51F8586CF77300.quest_subtitle: "&7Tier 1 — Bronze"
	quest.7C51F8586CF77300.quest_desc: ["&cBuff massivo de dano com baixa vida. Risco vs reward."]
	quest.516CD5A5EF0C6FC6.title: "Eldritch Amulet"
	quest.516CD5A5EF0C6FC6.quest_subtitle: "&fTier 2 — Vapor"
	quest.516CD5A5EF0C6FC6.quest_desc: ["&5Mantém keepInventory mesmo com Cursed Ring. Endgame."]
	quest.C50000000000FFFF.title: "Ring of the Seven Curses"
	quest.C50000000000FFFF.quest_desc: ["&6&lO ÁPICE&r — versão final do anel. Maximum risk, maximum reward. &aRecompensa:&r 2000 XP."]

