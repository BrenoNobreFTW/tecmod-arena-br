	quest.398C467A03D657CD.title: "Energy Cell — Starter"
	quest.398C467A03D657CD.quest_subtitle: "&7Tier 1 — Bronze"
	quest.398C467A03D657CD.quest_desc: [
		"&fSeu primeiro armazenamento Powah.&r"
