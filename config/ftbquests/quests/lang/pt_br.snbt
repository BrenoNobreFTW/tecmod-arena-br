	# === ENDERIO ===
	quest.4F00000000000001.title: "EnderIO — Indústria Sombria"
	quest.4F00000000000001.quest_subtitle: "&8Tier 0 — Despertar"
	quest.4F00000000000001.quest_desc: [
		"&6&lENDERIO&r"
		""
		"O mod tech &cmais clássico&r da era IC2/Tekkit. Especializado em &eligas alquímicas&r e &fconduits&r."
		""
		"&aLigas EnderIO famosas:&r"
		"&7• &cRedstone Alloy&r — conduits"
		"&7• &eEnergetic Alloy&r — circuitos"
		"&7• &dVibrant Alloy&r — endgame"
		"&7• &8Dark Steel&r — armadura"
		"&7• &fEnd Steel&r — endgame"
		""
		"&aFeatures icônicas:&r"
		"&7• &fCapacitor Bank&r — armazenamento massivo"
		"&7• &fConduits&r — energia/itens/fluidos em 1 cabo"
		"&7• &fPowered Spawner&r — auto-farm de mobs"
		"&7• &fVacuum Chest&r — coleta itens automaticamente"
	]

	quest.4F00000000000002.title: "Simple Alloy Smelter"
	quest.4F00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000002.quest_desc: [
		"&fA primeira máquina EnderIO.&r"
		""
		"Combina ingredientes em ligas. Não precisa de energia (usa carvão). Sua porta de entrada pra todas as outras ligas."
	]

	quest.4F00000000000003.title: "Redstone Alloy"
	quest.4F00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000003.quest_desc: [
		"&cA primeira liga.&r"
		""
		"Receita: 1 Iron + 1 Redstone + 1 Silicon (ou similar)."
		""
