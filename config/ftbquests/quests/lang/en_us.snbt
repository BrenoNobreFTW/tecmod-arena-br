	quest.176B7C69004C0933.quest_desc: [
		"&6&l>>> COMECE AQUI <<<&r"
		""
		"&7Este é o ponto de partida do &aCreate&r."
		""
		"&7&aProgressão sugerida:&r"
		"&71. Faça a &eWrench&7 (TOOLS - canto sup. esquerdo)"
		"&72. Faça os &eGoggles&7 (TOOLS)"
		"&73. Vá em &eTIERS&7 (esquerda) e faça &eAndesite Alloy&7 → &eAndesite Casing&7"
		"&74. Crafte o &eAndesite Mechanism&7 (chave do Create: Ages!)"
		"&75. Explore as outras seções em qualquer ordem"
		""
		"&6Seções:&r"
		"&7• &fROTATIONAL POWER&r — fontes de rotação"
		"&7• &fMACHINES&r — processamento (press, mixer, drill)"
		"&7• &fITEM LOGISTICS&r — funnels, tunnels, packaging"
		"&7• &fTIERS&r — Create: Ages (essencial pra progressão!)"
		"&7• &fFLUID LOGISTICS&r — pipes, pumps, tanks"
		"&7• &fTOOLS&r — wrench, goggles, signals"
		"&7• &fCONTRAPTIONS&r — moving structures"
		"&7• &fENDGAME&r — refined_radiance, shadow_steel"
		""
		"&6Recompensa inicial:&r 50 XP + 16 iron_nuggets + 8 oak_planks + 8 cobblestone"
	]
	quest.176B7C69004C0933.quest_subtitle: "2605 Comece pela liga de andesito"
