	quest.1DEF751E3E868662.quest_desc: [
		"Every journey starts with the basics."
		""
		"Break wood, make planks, craft sticks, and finally a &fwooden pickaxe&r."
		""
		"You'll need it to start mining stone and iron."
	]
	quest.1DEF751E3E868662.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1DEF751E3E868662.title: "Get a Wooden Pickaxe"
	quest.1E00000000000001.quest_desc: [
		"&6&lIMMERSIVE ENGINEERING&r"
		""
		"The &cmost aesthetic&r tech mod — large machines, impressive multiblocks, and a pure industrial revolution vibe."
		""
		"&aIC2-style progression with 3 voltages:&r"
		"&7• &eLV (Low Voltage)&r — 256 RF/t max per wire"
		"&7• &6MV (Medium Voltage)&r — 1024 RF/t"
		"&7• &cHV (High Voltage)&r — 4096 RF/t"
		""
		"&aNotable Multiblocks:&r"
		"&7• &fCoke Oven&r → Coal Coke + Creosote"
		"&7• &fBlast Furnace&r → Steel"
		"&7• &fExcavator&r → massive mining"
		"&7• &fGarden Cloche&r → automated farming"
		""
		"&7Tools: &fEngineer's Hammer&r and &fWire Cutter&r — you will use them a lot."
	]
	quest.1E00000000000001.quest_subtitle: "&8Tier 0 — Awakening"
	quest.1E00000000000001.title: "🔧 Immersive Engineering"
	quest.1E00000000000002.quest_desc: [
		"&fThe engineer's basic tools.&r"
		""
		"&fHammer&r — used to rotate blocks, assemble wire connectors, and process raw materials in some recipes."
		""
		"&fWire Cutter&r — cuts wire connections."
	]
	quest.1E00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000002.title: "Hammer and Wire Cutter"
	quest.1E00000000000003.quest_desc: [
		"&fThe bricks of the Coke Oven.&r"
		""
		"Coke Oven is a 3x3x3 multiblock. Build it with 27 Coke Oven Bricks + the Engineer's Hammer."
		""
		"&aProduces Coal Coke (burns 2x longer than coal) and Creosote Oil (fuel for Diesel)."
	]
	quest.1E00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000003.title: "Coke Oven Bricks"
	quest.1E00000000000004.quest_desc: [
		"&aThe first products of the Coke Oven.&r"
		""
		"Throw coal in, and out comes &fCoal Coke&r (strong fuel). Byproduct: &eCreosote Oil&r."
		""
		"&7Coal Coke is required for the Blast Furnace to make Steel."
	]
	quest.1E00000000000004.quest_subtitle: "&fTier 2 — Steam"
	quest.1E00000000000004.title: "Coal Coke + Creosote"
	quest.1E00000000000005.quest_desc: [
		"&fThe bricks of the Blast Furnace.&r"
		""
		"A 3x3x3 multiblock (similar to the Coke Oven). Build it to produce Steel."
		""
		"&7Recipe: Iron Ingot + Coal Coke = Steel Ingot."
	]
	quest.1E00000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.1E00000000000005.title: "Blast Furnace Bricks"
	quest.1E00000000000006.quest_desc: [
		"&fIE's Steel.&r"
		""
		"Different from Mekanism's Steel (but shares the &c#c:ingots/steel&r tag). AlmostUnified resolves duplication."
		""
		"&aUnlocks:&r tier 2 machines, scaffolding, and advanced multiblocks."
	]
	quest.1E00000000000006.quest_subtitle: "&fTier 2 — Steam"
	quest.1E00000000000006.title: "Steel Ingot"
	quest.1E00000000000007.quest_desc: [
		"&aClassic wind energy.&r"
		""
		"Place it high up (Y > 100). Transmits kinetic energy via Wooden Posts to a Kinetic Dynamo."
		""
		"&7Pure steampunk vibe. Useful + decorative."
	]
	quest.1E00000000000007.quest_subtitle: "&bTier 3 — Electric"
	quest.1E00000000000007.title: "Windmill"
	quest.1E00000000000008.quest_desc: [
		"&aConverts rotation into FE.&r"
		""
		"Receives rotation from a Windmill or Watermill. Output: LV (256 RF/t)."
		""
		"&7Your first source of electricity."
	]
	quest.1E00000000000008.quest_subtitle: "&bTier 3 — Electric"
	quest.1E00000000000008.title: "Kinetic Dynamo"
	quest.1E00000000000009.quest_desc: [
		"&aThermal energy (heat + cold).&r"
		""
		"Surround it with a hot block (Lava) AND a cold block (Ice / Water). The larger the difference = the more energy."
		""
		"&7Smart setup: 4 sides of lava + 4 sides of packed ice = A LOT of energy."
	]
	quest.1E00000000000009.quest_subtitle: "&bTier 3 — Electric"
	quest.1E00000000000009.title: "Thermoelectric Generator"
	quest.1E0000000000000A.quest_desc: [
		"&eThe first tier of electricity.&r"
		""
		"&fLV Wire Coil&r — wires"
		"&fLV Connector&r — plugs into machines/dynamos"
		"&fLV Capacitor&r — stores 100k FE"
		""
		"&7Limit: 256 RF/t per wire. Enough for the early-game."
	]
	quest.1E0000000000000A.quest_subtitle: "&bTier 3 — Electric"
	quest.1E0000000000000A.title: "LV — Low Voltage"
	quest.1E0000000000000B.quest_desc: [
		"&6The second tier.&r"
		""
		"&fMV Wire&r — 1024 RF/t"
		"&fMV Capacitor&r — 1M FE"
		""
		"&aRequires Steel. Ideal tier for serious automation."
	]
	quest.1E0000000000000B.quest_subtitle: "&dTier 4 — Advanced"
	quest.1E0000000000000B.title: "MV — Medium Voltage"
	quest.1E0000000000000C.quest_desc: [
		"&cMaximum IE tier.&r"
		""
		"&fHV Wire&r — 4096 RF/t"
		"&fHV Capacitor&r — 4M FE"
		""
		"&aRequires Aluminum + Steel. Endgame tier."
	]
	quest.1E0000000000000C.quest_subtitle: "&dTier 4 — Advanced"
	quest.1E0000000000000C.title: "🏆 HV — High Voltage"
	quest.1E0000000000000D.quest_desc: [
		"&aFarming inside a glass dome.&r"
		""
		"Place a seed in the slot, water in the tank, and dirt/sand/etc in the bottom slot. It grows continuously."
		""
		"&7Works with:&r wheat, beetroot, cactus, melons, and even flowers."
		""
		"&aTip:&r looks and works beautifully with Mystical Agriculture seeds!"
	]
	quest.1E0000000000000D.quest_subtitle: "&bTier 3 — Electric"
	quest.1E0000000000000D.title: "Garden Cloche"
	quest.1E0000000000000E.quest_desc: [
		"&fThe visual structure of IE.&r"
		""
		"Used in both decorative and functional multiblocks. Pure industrial revolution vibe."
		""
		"&aBase for:&r Excavator, Diesel Generator, Crusher (endgame multiblocks)."
	]
	quest.1E0000000000000E.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E0000000000000E.title: "Steel Scaffolding"
	quest.1E0000000000000F.quest_desc: [
		"&cCombustion multiblock.&r"
		""
		"Burns Diesel (refined from Oil via Refinery) or Creosote Oil. Massive output."
		""
		"&aGenerates 4096 RF/t — easily powers an entire HV factory."
	]
	quest.1E0000000000000F.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E0000000000000F.title: "Diesel Generator (optional)"
	quest.1E00000000FFFFFF.quest_desc: [
		"&6&lIE COMPLETED&r"
		""
		"You mastered Immersive Engineering. Coke Oven, Blast Furnace, multiblocks, and HV active."
		""
		"&aReward:&r 16× Steel + Netherite Ingot + 1000 XP."
		""
		"&7Next step:&r Excavator + Diesel Generator for massive industrial mining."
	]
	quest.1E00000000FFFFFF.quest_subtitle: "&6Tier 5 — Endgame"
	quest.1E00000000FFFFFF.title: "🏆 IMMERSIVE INDUSTRY"
