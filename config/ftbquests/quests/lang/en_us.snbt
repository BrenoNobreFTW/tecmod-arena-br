	quest.2100000000000001.quest_desc: [
		"&6&lINDUSTRIAL FOREGOING&r"
		""
		"The spiritual successor to MFR (MineFactory Reloaded). Specialized in &abiological automation&r — farms, ranches, slaughterhouses."
		""
		"&aIconic Machines:&r"
		"&7• &fPlant Sower / Gatherer&r — automatic farming"
		"&7• &fAnimal Rancher&r — milk/eggs/wool without killing"
		"&7• &fMob Slaughter Factory&r — XP + meat"
		"&7• &fBioreactor + Biofuel Generator&r — bio energy"
		"&7• &fBlack Hole Unit&r — INFINITE storage"
		""
		"&aKey material: Plastic.&r"
	]
	quest.2100000000000001.quest_subtitle: "&8Tier 0 — Awakening"
	quest.2100000000000001.title: "🌱 Industrial Foregoing"
	quest.2100000000000002.quest_desc: [
		"&fThe 'industrial plastic' of the mod.&r"
		""
		"Make it via Latex (from tree tapping) → Plastic Sheet."
		""
		"&7Required in almost all IF machines."
	]
	quest.2100000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000002.title: "Plastic"
	quest.2100000000000003.quest_desc: [
		"&aPlants seeds automatically.&r"
		""
		"Define the area (3x3 to 9x9 with upgrades). Seeds from its inventory become a plantation."
		""
		"&7Combine with a Plant Gatherer for a 100% automated farm."
	]
	quest.2100000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000003.title: "Plant Sower"
	quest.2100000000000004.quest_desc: [
		"&aHarvests fully grown plants.&r"
		""
		"Works with any crop: wheat, beetroot, cocoa, mystical agriculture."
		""
		"&aIdeal setup:&r Plant Sower + Plant Gatherer = infinite automatic farm."
	]
	quest.2100000000000004.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000004.title: "Plant Gatherer"
	quest.2100000000000005.quest_desc: [
		"&aMilk, eggs, wool — without killing.&r"
		""
		"Ranches mobs non-violently. Cows give milk, sheep give wool, chickens give eggs."
		""
		"&7Vegan-friendly."
	]
	quest.2100000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000005.title: "Animal Rancher"
	quest.2100000000000006.quest_desc: [
		"&cKills mobs and collects drops.&r"
		""
		"Slaughters hostiles. Combine with a Powered Spawner (EnderIO) or a vanilla mob farm."
		""
		"&aOutput:&r XP as fluid + Meat (for the Bioreactor)."
	]
	quest.2100000000000006.quest_subtitle: "&7Tier 1 — Bronze"
	quest.2100000000000006.title: "Mob Slaughter Factory"
	quest.2100000000000007.quest_desc: [
		"&aTransforms organic matter into Biofuel.&r"
		""
		"Accepts: wheat, potatoes, cocoa, any plant. More &cdiversity&r in inputs = more biofuel per slot."
		""
		"&7Combine with Mob Slaughter for meat + Plant Gatherer for plants."
	]
	quest.2100000000000007.quest_subtitle: "&fTier 2 — Steam"
	quest.2100000000000007.title: "Bioreactor"
	quest.2100000000000008.quest_desc: [
		"&aBurns Biofuel to generate FE.&r"
		""
		"Respectable output. Combine with a Bioreactor for a self-sustaining base."
	]
	quest.2100000000000008.quest_subtitle: "&fTier 2 — Steam"
	quest.2100000000000008.title: "Biofuel Generator"
	quest.2100000000000009.quest_desc: [
		"&dBackpack with &cUNLIMITED&d storage and infinite functionalities.&r"
		""
		"&fInfinity Backpack&r — holds millions of items, feeds you, gives effects, and more."
		""
		"&aUseful for:&r exploration, massive ore farms, long trips."
	]
