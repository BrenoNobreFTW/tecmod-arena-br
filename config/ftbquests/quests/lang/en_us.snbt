	quest.AE00000000000001.quest_desc: [
		"&6&lAPPLIED ENERGISTICS 2&r"
		""
		"The &fmost powerful&r storage system in modded Minecraft. AE2 isn't just a chest — it's a &cNETWORK&r."
		""
		"&aFundamentals:&r"
		"&7• &fCertus Quartz&r — base resource"
		"&7• &fFluix Crystal&r — network energy"
		"&7• &fProcessors&r — Logic / Calculation / Engineering"
		"&7• &fME Drive + Storage Cells&r — stores everything"
		"&7• &fCrafting Terminal&r — interface"
		"&7• &fPattern Provider + Molecular Assembler&r — auto-crafting"
		""
		"&aEndgame:&r"
		"&7• &fME Controller&r (multiblock)"
		"&7• &fQuantum Network Bridge&r (long-distance)"
		"&7• &fSpatial Storage&r (saves entire regions)"
		"&7• &fWireless Terminal&r (remote access)"
		""
		"&7Comparison: &eRefined Storage&r is simpler, &fAE2&r is more technical but infinitely more powerful."
	]
	quest.AE00000000000001.quest_subtitle: "The definitive digital network"
	quest.AE00000000000001.title: "💾 Applied Energistics 2"
	quest.AE00000000000002.quest_desc: [
		"&fThe base resource for everything in AE2.&r"
		""
		"&7How to obtain:"
		"&7• Mine &eCertus Quartz Ore&r (overworld, similar to nether quartz)"
		"&7• Grow a &fCertus Seed&r in water with Charged Certus to speed it up"
	]
	quest.AE00000000000002.title: "Certus Quartz Crystal"
	quest.AE00000000000003.quest_desc: [
		"&fEnergy-less processing.&r"
		""
		"The Grindstone grinds ores manually — no electricity required. Useful for processing Certus, Fluix, iron, and gold in the early stages."
		""
		"&aTip:&r it doubles some ores without needing Mekanism."
	]
	quest.AE00000000000003.title: "Quartz Grindstone"
	quest.AE00000000000004.quest_desc: [
		"&aThe first electric AE2 machine.&r"
		""
		"Receives energy (FE) and &echarges&r:"
		"&7• Certus Quartz Crystal → Charged Certus"
		"&7• AE2 Items (drives, terminals, etc.)"
		""
		"&7Recipe: requires Wood + Iron + Quartz."
	]
	quest.AE00000000000004.title: "Charger"
	quest.AE00000000000005.quest_desc: [
		"&eEnergized version of Certus.&r"
		""
		"Required to make Fluix Crystals and processors."
		""
		"&aTip:&r throw a Certus Crystal into a block of water with Redstone + Nether Quartz and strike it with lightning = natural Fluix."
	]
	quest.AE00000000000005.title: "Charged Certus Quartz"
	quest.AE00000000000006.quest_desc: [
		"&dThe 'blood' of the AE2 network.&r"
		""
		"Used to make cables, processors, and conduits. Everything in the network needs Fluix."
		""
		"&7Charger Recipe:&r 1 Charged Certus + 1 Nether Quartz + 1 Redstone (in water!) = Fluix Dust → crystal"
	]
	quest.AE00000000000006.title: "Fluix Crystal"
	quest.AE00000000000007.quest_desc: [
		"&fThe machine that makes processors.&r"
		""
		"Receives presses + materials and produces processors. Each processor type requires a specific press."
		""
		"&7The 4 presses (rare drops from Meteorites):&r"
		"&7• Logic Press"
		"&7• Calculation Press"
		"&7• Engineering Press"
		"&7• Silicon Press"
	]
	quest.AE00000000000007.quest_subtitle: "Manufactures processors"
	quest.AE00000000000007.title: "Inscriber"
	quest.AE00000000000008.quest_desc: [
		"&eBasic processor.&r"
		""
		"Made with Logic Press + Gold + Silicon."
		""
		"&7Used in: cables, drives, basic storage cells."
	]
	quest.AE00000000000008.title: "Logic Processor"
	quest.AE00000000000009.quest_desc: [
		"&bMedium processor.&r"
		""
		"Calc Press + Pure Certus + Silicon."
		""
		"&7Used in: terminals, formation cores, etc."
	]
	quest.AE00000000000009.title: "Calculation Processor"
	quest.AE0000000000000A.quest_desc: [
		"&dAdvanced processor.&r"
		""
		"Eng Press + Diamond + Silicon."
		""
		"&7Used in: Pattern Providers, Molecular Assemblers, ME Controllers."
	]
	quest.AE0000000000000A.title: "Engineering Processor"
	quest.AE0000000000000B.quest_desc: [
		"&fThe backbone of the network.&r"
		""
		"Connects machines, terminals, and drives. Every block needs to be connected."
		""
		"&7Types:&r Glass Cable (1 channel), Smart Cable (shows channels), Dense Cable (32 channels)."
	]
	quest.AE0000000000000B.title: "ME Cable"
	quest.AE0000000000000C.quest_desc: [
		"&aThe box that holds your Storage Cells.&r"
		""
		"Each Drive accepts 10 cells. Plug it into a network cable and everything inside becomes part of your storage."
	]
	quest.AE0000000000000C.title: "ME Drive"
	quest.AE0000000000000D.quest_desc: [
		"&aThe initial storage tiers.&r"
		""
		"&7• 1k = 8,192 items (up to 63 types)"
		"&7• 4k = 32,768 items (up to 63 types)"
		""
		"&aTrade-off:&r the more &edifferent types&r of items you store, the fewer &ftotal items&r it can hold."
	]
	quest.AE0000000000000D.title: "Storage Cells (1k and 4k)"
	quest.AE0000000000000E.quest_desc: [
		"&aHigh storage tiers.&r"
		""
		"&7• 16k = 131,072 items"
		"&7• 64k = 524,288 items (up to 63 types)"
		""
		"&aPractically 'infinite' storage for general use.&r"
	]
	quest.AE0000000000000E.title: "Storage Cells (16k and 64k)"
	quest.AE0000000000000F.quest_desc: [
		"&aThe main screen of the network.&r"
		""
		"Access all storage, see quantities, and craft directly in a 3x3 grid using items from the network."
		""
		"&7A wireless version exists via &fAE2WTLib&r — granting remote access to the network."
	]
	quest.AE0000000000000F.quest_subtitle: "Your main interface"
	quest.AE0000000000000F.title: "Crafting Terminal"
	quest.AE00000000000010.quest_desc: [
		"&6The heart of auto-crafting.&r"
		""
		"Encode patterns with a Pattern Encoder and place them in the Pattern Provider. When the network needs an item crafted, it sends the ingredients."
		""
		"&7Directs to:&r Molecular Assembler (normal crafting) or external machines (smelter, mixer, etc.)."
	]
	quest.AE00000000000010.quest_subtitle: "Where patterns live"
	quest.AE00000000000010.title: "Pattern Provider"
	quest.AE00000000000011.quest_desc: [
		"&aThe invisible 'crafter'.&r"
		""
		"Together with a Pattern Provider, it automates 3x3 crafting. Each pattern needs a Provider + Assembler pairing."
		""
		"&aWith this, your network will craft &eANY&r 3x3 recipe without you."
	]
	quest.AE00000000000011.title: "Molecular Assembler"
	quest.AE00000000000012.quest_desc: [
		"&fThe CPU that orchestrates massive crafting.&r"
		""
		"A multiblock combining:"
		"&7• &fCrafting Storage&r (cells dedicated to crafting)"
		"&7• &fCrafting Co-Processing Unit&r (parallel recipe handling)"
		"&7• &fCrafting Accelerator&r (speed boosts)"
		""
		"&aLarge setup = can craft recipes with 1000+ ingredients in seconds."
	]
	quest.AE00000000000012.quest_subtitle: "Auto-crafting at scale"
	quest.AE00000000000012.title: "Crafting CPU (Multiblock)"
	quest.AE00000000000013.quest_desc: [
		"&aThe energy gateway to the network.&r"
		""
		"Accepts FE (from Mekanism, IE, Powah, etc.) and converts it into AE — the network's internal currency."
		""
		"&7Important:&r AE2 DOES NOT consume much FE while idle, but during crafting it can spike heavily."
	]
	quest.AE00000000000013.title: "Energy Acceptor"
	quest.AE00000000000014.quest_desc: [
		"&aThe central multiblock of complex networks.&r"
		""
		"Without a Controller: 8 channels max."
		"With a Controller: 32 channels per face × 6 faces = LOTS of connections."
		""
		"&7You need this when:&r"
		"&7• Running multiple parallel auto-crafts"
		"&7• Using wireless terminals"
		"&7• Establishing a Quantum Link"
	]
	quest.AE00000000000014.quest_subtitle: "The core of large networks"
	quest.AE00000000000014.title: "ME Controller"
	quest.AE00000000000015.quest_desc: [
		"&aAccess the network from anywhere.&r"
		""
		"Keep it in your hotbar, hold right-click = opens the remote Crafting Terminal."
		""
		"&7Booster cards increase the range. Extremely useful for mining — drop items straight into the network."
	]
	quest.AE00000000000015.title: "Wireless Terminal (optional)"
	quest.AE00000000000016.quest_desc: [
		"&dNetworks connected across dimensions.&r"
		""
		"2 Quantum Rings with an entangled Singularity = a channel between 2 networks at any distance."
		""
		"&aUseful for:&r outpost mining, connecting a Nether/End base to the overworld."
	]
	quest.AE00000000000016.quest_subtitle: "Long-distance"
	quest.AE00000000000016.title: "Quantum Link (optional)"
	quest.AE00000000000017.quest_desc: [
		"&dStore ENTIRE REGIONS.&r"
		""
		"Spatial Cells save a cubic region of the world (entities, blocks, everything). Use Spatial Pylons to build a 'transfer room'."
		""
		"&aIdeal for:&r moving whole bases, transporting active reactors, etc."
	]
	quest.AE00000000000017.title: "Spatial Storage (optional)"
	quest.AE0000000000FFFF.quest_desc: [
		"&6&lFULL MASTERY OF THE NETWORK&r"
		""
		"You have built the definitive network. Everything is automated, connected, and optimized."
		""
		"&7Reward:&r 8× ME 256k Cell + Netherite Block + 1000 XP."
		""
		"&aNext step:&r combine with a Mekasuit + Wireless Terminal + Mekanism Reactor = true endgame."
	]
	quest.AE0000000000FFFF.title: "🏆 TOTAL NETWORK"
	quest.B000000000000001.quest_desc: [
		"&6&lPOWAH&r"
		""
		"A mod focused on &cpure energy&r. No processing machines — only generation, storage, and transmission of FE."
		""
		"&aTiers (in order):&r"
		"&7• &fStarter&r — early-game"
		"&7• &fBasic&r"
		"&7• &fHardened&r"
		"&7• &cBlazing&r"
		"&7• &dNiotic&r"
		"&7• &5Spirited&r"
		"&7• &6Nitro&r — endgame"
		""
		"&aEach tier offers:&r reactor + cell + solar + magmator + cables."
		""
		"&7Useful to complement Mekanism/IE with massive energy storage."
	]
	quest.B000000000000001.quest_subtitle: "Starter → Nitro"
	quest.B000000000000001.title: "⚡ Powah — The Energy Era"
	quest.B000000000000002.quest_desc: [
		"&fThe Powah iron.&r"
		""
		"Crafted with Iron + Dielectric Paste. Used in almost all Powah components."
	]
	quest.B000000000000002.title: "Steel Energized"
	quest.B000000000000003.quest_desc: [
		"&fYour first Powah storage.&r"
		""
		"Modest capacity, but gets the job done for the early-game. Each side is configurable (input/output/none)."
	]
	quest.B000000000000003.title: "Energy Cell — Starter"
	quest.B000000000000004.quest_desc: [
		"&aThe starter reactor.&r"
		""
		"A multiblock that requires fuel and coolant. Unlike Mekanism Fission, it is simple and safe."
		""
		"&7Output: a few hundred RF/t."
	]
	quest.B000000000000004.title: "Reactor — Starter"
	quest.B000000000000005.quest_desc: [
		"&aPassive generators.&r"
		""
		"&fSolar Panel&r — sunlight = energy"
		"&fMagmator&r — burns Lava (lava bucket = A LOT of energy)"
		""
		"&7Combine both for 24/7 coverage."
	]
	quest.B000000000000005.title: "Solar / Magmator Starter"
	quest.B000000000000006.quest_desc: [
		"&fTier 2 — decent capacity.&r"
		""
		"Useful for the mid-game while you don't have a Mekanism Energy Cube."
	]
	quest.B000000000000006.title: "Energy Cell — Basic"
	quest.B000000000000007.quest_desc: [
		"&6Tier 3.&r"
		""
		"Real capacity begins to play a role here."
	]
	quest.B000000000000007.title: "Energy Cell — Hardened"
	quest.B000000000000008.quest_desc: [
		"&cTier 4 — Blazing.&r"
		""
		"Material: Blaze. Massive capacity. Starts competing with Advanced Mekanism."
	]
	quest.B000000000000008.title: "Energy Cell — Blazing"
	quest.B000000000000009.quest_desc: [
		"&dTier 5 — Niotic.&r"
		""
		"Material: Diamonds. The endgame begins."
	]
	quest.B000000000000009.title: "Energy Cell — Niotic"
	quest.B00000000000000A.quest_desc: [
		"&5Tier 6 — Spirited.&r"
		""
		"Material: Emeralds. Absurd capacity."
	]
	quest.B00000000000000A.title: "Energy Cell — Spirited"
	quest.B00000000000000B.quest_desc: [
		"&6Tier 7 — Nitro. Powah Endgame.&r"
		""
		"Nominal capacity: billions of FE. Nitro Cell + Nitro Reactor = your factory will never run out of energy again."
	]
	quest.B00000000000000B.quest_subtitle: "The apex of storage"
	quest.B00000000000000B.title: "🏆 Energy Cell — Nitro"
	quest.B00000000000000C.quest_desc: [
		"&6The endgame reactor.&r"
		""
		"Complex multiblock. Massive output. Requires refined Uraninite (Powah specific) and advanced coolants."
		""
		"&7Replaces multiple Mekanism Fission reactors in a single machine."
	]
	quest.B00000000000000C.title: "Reactor — Nitro"
	quest.B00000000000000D.quest_desc: [
		"&aWireless charging for you.&r"
		""
		"Place the Transmitter in your base. Equip an Aura Heart in your Curios slot. FE items in your inventory will charge automatically."
		""
		"&7Excellent combined with a Mekasuit or Powah Energizing Rod."
	]
	quest.B00000000000000D.title: "Player Transmitter (optional)"
	quest.B0000000000FFFFF.quest_desc: [
		"&6&lPOWAH ENDGAME&r"
		""
		"You mastered all Powah tiers. Nitro Reactor + Nitro Cell = infinite energy."
		""
		"&aReward:&r 4× Nitro Cell + Netherite Ingot + 1000 XP."
	]
	quest.B0000000000FFFFF.title: "🏆 ENERGY EMPIRE"
	quest.C0000000000C0001.quest_desc: [
		"&6&lExplore ALL Create blocks.&r"
		""
		"&7Each flower is a category: Kinetic, Processing, Logistic, Storage, Movement, Schematic, Materials, Tools."
	]
	quest.C0000000000C0001.quest_subtitle: "Start of steampunk"
	quest.C0000000000C0001.title: "Welcome to Create"
	quest.C100000000C00010.quest_desc: ["&7Master all Create items in this category."]
	quest.C100000000C00010.quest_subtitle: "Category hub"
	quest.C100000000C00010.title: "Materials"
	quest.C1140000C0001000.quest_subtitle: "Materials"
	quest.C1140000C0001000.title: "Andesite Alloy"
	quest.C1150000C0001000.quest_subtitle: "Materials"
	quest.C1150000C0001000.title: "Brass Ingot"
	quest.C1160000C0001000.quest_subtitle: "Materials"
	quest.C1160000C0001000.title: "Zinc Ingot"
	quest.C1170000C0001000.quest_subtitle: "Materials"
	quest.C1170000C0001000.title: "Rose Quartz"
	quest.C1180000C0001000.quest_subtitle: "Materials"
	quest.C1180000C0001000.title: "Polished Rose Quartz"
	quest.C1190000C0001000.quest_subtitle: "Materials"
	quest.C1190000C0001000.title: "Sturdy Sheet"
	quest.C11A0000C0001000.quest_subtitle: "Materials"
	quest.C11A0000C0001000.title: "Precision Mechanism"
	quest.C11B0000C0001000.quest_subtitle: "Materials"
	quest.C11B0000C0001000.title: "Electron Tube"
	quest.C11C0000C0001000.quest_subtitle: "Materials"
	quest.C11C0000C0001000.title: "Brass Hand"
	quest.C11D0000C0001000.quest_subtitle: "Materials"
	quest.C11D0000C0001000.title: "Iron Sheet"
	quest.C200000000C00011.quest_desc: ["&7Master all Create items in this category."]
	quest.C200000000C00011.quest_subtitle: "Category hub"
	quest.C200000000C00011.title: "Tools"
	quest.C2140000C0001100.quest_subtitle: "Tools"
	quest.C2140000C0001100.title: "Wrench"
	quest.C2150000C0001100.quest_subtitle: "Tools"
	quest.C2150000C0001100.title: "Engineer's Goggles"
	quest.C2160000C0001100.quest_subtitle: "Tools"
	quest.C2160000C0001100.title: "Potato Cannon"
	quest.C2170000C0001100.quest_subtitle: "Tools"
	quest.C2170000C0001100.title: "Minecart Coupling"
	quest.C2180000C0001100.quest_subtitle: "Tools"
	quest.C2180000C0001100.title: "Super Glue"
	quest.C2190000C0001100.quest_subtitle: "Tools"
	quest.C2190000C0001100.title: "Cardboard Sword"
	quest.C21A0000C0001100.quest_subtitle: "Tools"
	quest.C21A0000C0001100.title: "Cardboard Armor"
	quest.C21B0000C0001100.quest_subtitle: "Tools"
	quest.C21B0000C0001100.title: "Train Track"
	quest.C21C0000C0001100.quest_subtitle: "Tools"
	quest.C21C0000C0001100.title: "Track Signal"
	quest.C21D0000C0001100.quest_subtitle: "Tools"
	quest.C21D0000C0001100.title: "Train Door"
	quest.C500000000000001.quest_desc: [
		"&6&lENIGMATIC LEGACY PLUS&r"
		""
		"A mod centered around &ccurses&r and &ecursed items&r — powerful buffs with terrible costs."
		""
		"&aPillar of the mod: the Ring of Seven Curses.&r Accept it = gain +loot/damage/XP. But you will suffer:"
		"&7• Insomnia (phantoms)"
		"&7• Take more damage from monsters"
		"&7• Reduced armor effectiveness"
		"&7• Eternal burning in lava"
		"&7• Soul Crystals (lose part of your soul on death)"
		""
		"&7In our pack: dying with the ring = you permanently lose 1 heart until you regenerate it."
	]
	quest.C500000000000001.quest_subtitle: "Accept the burden"
	quest.C500000000000001.title: "🩸 Enigmatic Legacy — The 7 Curses"
	quest.C500000000000002.quest_desc: ["&5The beginning. Equip it and accept the 7 curses. Turning back is &cdifficult&r."]
	quest.C500000000000002.title: "Cursed Ring"
	quest.C500000000000003.quest_desc: ["&dRecover lost souls. 1 soul = 1 heart restored."]
	quest.C500000000000003.title: "Soul Crystal"
	quest.C500000000000004.quest_desc: ["&cPermanently regenerates 1 lost heart. Rare drop from bosses."]
	quest.C500000000000004.title: "Heart of Creation"
	quest.C500000000000005.quest_desc: ["&cMassive damage buff at low health. Risk vs reward."]
	quest.C500000000000005.title: "Berserk Emblem"
	quest.C500000000000006.quest_desc: ["&5Maintains keepInventory even with the Cursed Ring. Endgame."]
	quest.C500000000000006.title: "Eldritch Amulet"
	quest.C50000000000FFFF.quest_desc: ["&6&lTHE APEX&r — final version of the ring. Maximum risk, maximum reward. &aReward:&r 2000 XP."]
	quest.C50000000000FFFF.title: "🏆 Ring of the Seven Curses"
	quest.CA00000000000001.quest_desc: [
		"&6&lTHE STEAM AGE AWAKENS&r"
		""
		"Iron is heavy. Stone is dead. But the moment the first gear bites into another — the world changes."
		""
		"&eCreate&r is not magic. It is pure &cmechanics&r:"
		"&7• &fShafts&r — transmit rotation"
		"&7• &fCogwheels&r — distribute it"
		"&7• &fMachines&r — consume rotation"
		"&7• Everything is measured in &eRPM&r and &cStress (SU)&r"
		""
		"&aChapter Progression:"
		"&71. &7Andesite Tier &8(basics)"
		"&72. &6Brass Tier &8(intermediate)"
		"&73. &cCopper Tier &8(fluids)"
		"&74. &bSteam Tier &8(endgame: Steam Engine)"
		""
		"&7Press &eW&r on Create items in JEI/EMI to view the &fPonder&r — a 3D animation teaching you how to use it!"
	]
	quest.CA00000000000001.quest_subtitle: "Where iron learns to spin"
	quest.CA00000000000001.title: "⚙️ Create — The Steam Age"
	quest.CA00000000000002.quest_desc: [
		"The foundational ingredient of the mechanical age."
		""
		"&7Recipe:&r 1 Iron Nugget + 1 Andesite in the Crafting Table."
		""
		"&aTip:&r you will spend a &eLOT&r of this. Automate it with a Mechanical Mixer later."
	]
	quest.CA00000000000002.title: "Andesite Alloy"
	quest.CA00000000000003.quest_desc: [
		"Your &efirst power source&r."
		""
		"Hold right-click to generate 32 SU. Good enough to power 1-2 small machines."
		""
		"&aUseful for:&r testing setups before building a Water Wheel."
	]
	quest.CA00000000000003.title: "Hand Crank"
	quest.CA00000000000004.quest_desc: [
		"&fThe nerves of the factory.&r"
		""
		"&fShaft&r — transmits in a straight line"
		"&fCogwheel&r — transmits between parallel shafts"
		"&fLarge Cogwheel&r — multiplies/divides speed"
		""
		"&aKeep 8+ of each in your inventory at all times."
	]
	quest.CA00000000000004.title: "Shafts and Cogwheels"
	quest.CA00000000000005.quest_desc: [
		"&bClean, infinite, free energy.&r"
		""
		"Place it in a water current flowing on all 4 faces — generates continuous RPM with no fuel."
		""
		"&aBest early-game option for 24/7 automation."
	]
	quest.CA00000000000005.title: "Water Wheel"
	quest.CA00000000000006.quest_desc: [
		"&fGrind with rotation.&r"
		""
		"The Millstone grinds ores into dust (1 ore = 1 dust). Works with any rotation speed."
		""
		"&7Recipe: Andesite Casing + Cogwheel"
		""
		"&aUseful for:&r early ore doubling before tier 2."
	]
	quest.CA00000000000006.title: "Millstone"
	quest.CA00000000000007.quest_desc: [
		"&fCompress and press with mechanical force.&r"
		""
		"Place above a &eDepot&r or &fBelt&r with items. The Press transforms:"
		"&7• Iron Ingot → Iron Sheet"
		"&7• Gold Ingot → Gold Sheet"
		"&7• Etc."
		""
		"&aAlso used in &eSequenced Assembly&r later on!"
	]
	quest.CA00000000000007.title: "Mechanical Press"
	quest.CA00000000000008.quest_desc: [
		"&fThe alchemical fan.&r"
		""
		"Point it towards:"
		"&7• &cFire&r → smelts items (smoke)"
		"&7• &bWater&r → washes items (washing → ore → 2 nuggets)"
		"&7• &ePure Air&r → pushes/pulls entities"
		""
		"&aWashing duplicates ores like copper, gold, etc!"
	]
	quest.CA00000000000008.title: "Encased Fan"
	quest.CA00000000000009.quest_desc: [
		"&aThe heart of automated metallurgy.&r"
		""
		"Setup: &fBasin&r on the floor, &fMixer&r 2 blocks above it, with a connected shaft."
		""
		"Combines items + fluids automatically. Basic recipe:"
		"&7Andesite + Iron Nugget → Andesite Alloy"
		""
		"&aNext step:&r Brass!"
	]
	quest.CA00000000000009.title: "Mechanical Mixer"
	quest.CA0000000000000A.quest_desc: [
		"&6Create's tier 2 material.&r"
		""
		"&7Recipe in Mixer:&r"
		"&7• Copper + Zinc → Brass Ingot"
		""
		"&aBrass unlocks:&r Mechanical Crafter, Arm, Belts, advanced Funnels, and Sequenced Assembly."
	]
	quest.CA0000000000000A.title: "Brass"
	quest.CA0000000000000B.quest_desc: [
		"&6The base block for tier 2 machines.&r"
		""
		"&7Recipe: Stripped Wood + Brass Sheets (Press)"
		""
		"&aFoundation for:&r Mechanical Crafters, Arms, and most advanced machines."
	]
	quest.CA0000000000000B.title: "Brass Casing"
	quest.CA0000000000000C.quest_desc: [
		"&aAutomatic crafting in shape!&r"
		""
		"Place in a grid (3x3 or larger). Configure the arrows with a &eWrench&r to form a path."
		""
		"Each Crafter receives 1 ingredient. The result comes out the last one."
		""
		"&aIdeal for:&r Refined Radiance, Shadow Steel, and complex recipes like Steel Casing."
	]
	quest.CA0000000000000C.title: "Mechanical Crafter"
	quest.CA0000000000000D.quest_desc: [
		"&6The programmable robotic arm.&r"
		""
		"Program it via Wrench (click on inputs and outputs). It picks up items from up to 5 sources and distributes them to 5 destinations."
		""
		"&aPerfect for:&r feeding Crafters, sorting ores, organizing Sequenced Assembly outputs."
	]
	quest.CA0000000000000D.title: "Mechanical Arm"
	quest.CA0000000000000E.quest_desc: [
		"&fThe static table.&r"
		""
		"Unlike a Belt, the Depot &cholds&r the item in place for the Press, Deployer, and others to act upon."
		""
		"&aEssential for Sequenced Assembly Lines."
	]
	quest.CA0000000000000E.title: "Depot"
	quest.CA0000000000000F.quest_desc: [
		"&6&lTHE ENDGAME BRASS ITEM&r"
		""
		"Made in a 5+ step &eSequenced Assembly&r:"
		"&71. Golden Sheet enters"
		"&72. Deployer applies Cogwheel"
		"&73. Deployer applies Iron Nugget"
		"&74. Press hammers it down"
		"&75. (loop several times)"
		"&76. Result: &6Precision Mechanism&r"
		""
		"&aPrerequisite for:&r Copper Casing, Steam Engine, and high-tier machines."
	]
	quest.CA0000000000000F.quest_subtitle: "Brass Endgame"
	quest.CA0000000000000F.title: "Precision Mechanism"
	quest.CA00000000000010.quest_desc: [
		"&cThe fluid casing.&r"
		""
		"Required for machines that &emanipulate liquids&r — Spouts, Fluid Tanks, Pipes, Pumps."
		""
		"&7Recipe:&r requires Precision Mechanism + Copper Sheets."
	]
	quest.CA00000000000010.title: "Copper Casing"
	quest.CA00000000000011.quest_desc: [
		"&aFluid logistics.&r"
		""
		"&fSpout&r — pours fluid onto items (enchanting potions, obsidian lava)"
		"&fFluid Pipe&r — transports fluids much like a Belt does for items"
		""
		"&aCombine with a &eHose Pulley&r to suck up oceans!"
	]
	quest.CA00000000000011.title: "Spouts and Pipes"
	quest.CA00000000000012.quest_desc: [
		"&fStorage at scale.&r"
		""
		"&fFluid Tank&r — holds 8000 mB. Build as a multiblock for larger capacity!"
		"&fItem Vault&r — holds items, multiblock for industrial scale."
		""
		"&aBoth multiblocks grow in height/width without a cap."
	]
	quest.CA00000000000012.title: "Tanks and Vaults"
	quest.CA00000000000013.quest_desc: [
		"&cThe heart of steam.&r"
		""
		"Capture a Blaze from the Nether using an Empty Blaze Burner. Feed it with:"
		"&7• Coal, wood (normal heat)"
		"&7• Lava, blaze rod, oil (super-heated!)"
		""
		"&aSuper-heated is required for the Steam Engine to reach max power."
	]
	quest.CA00000000000013.title: "Blaze Burner"
	quest.CA00000000000014.quest_desc: [
		"&6&lTHE MACHINE THAT DEFINES THE ERA&r"
		""
		"Complete setup:"
		"&71. Super-heated &fBlaze Burner&r"
		"&72. &fFluid Tank&r with water on top"
		"&73. &eSteam Engine&r connected to the side"
		"&74. More Engines = more SU (up to &c1024 SU&r per engine!)"
		""
		"&aReplaces 4-8 Water Wheels. Truly the kinetic endgame."
	]
	quest.CA00000000000014.quest_subtitle: "Create Endgame"
	quest.CA00000000000014.title: "🚂 Steam Engine"
	quest.CA00000000000015.quest_desc: [
		"&fCuts everything in front of it.&r"
		""
		"&7Functions:&r"
		"&7• Pointing at a tree → chops it down and processes it"
		"&7• Pointing down at a Belt → cuts items (wood → planks, etc.)"
		""
		"&aOptional&r but extremely useful for tree farms."
	]
	quest.CA00000000000015.title: "Mechanical Saw"
	quest.CA00000000000016.quest_desc: [
		"&fMoves fluids.&r"
		""
		"Connected to Fluid Pipes, forces the flow direction."
		""
		"&aOptional&r but necessary to distribute fluids at scale."
	]
	quest.CA00000000000016.title: "Mechanical Pump"
	quest.CA00000000000017.quest_desc: [
		"&fConstructs buildings automatically!&r"
		""
		"Loads a schematic (.nbt) and shoots blocks from the adjacent inventory to build it all."
		""
		"&7Limitations:&r consumes gunpowder + blocks. Does not build entities."
		""
		"&aPerfect for:&r replicating entire bases."
	]
	quest.CA00000000000017.title: "Schematicannon"
	quest.CA00000000000018.quest_desc: [
		"&6&lCREATE'S FINAL OBJECTIVE&r"
		""
		"Provide 8 Precision Mechanisms — produced automatically."
		""
		"&7Expected setup:"
		"&71. Steam Engine powering the factory"
		"&72. Mechanical Crafters in a grid making the sequence"
		"&73. Mechanical Arms distributing items"
		"&74. AE2/Storage inputting materials"
		""
		"&aReward:&r material for the next Era — &fNetherite Ingot&r + 1000 XP."
		""
		"&7Suggested next chapters: Mekanism, Immersive Engineering, or PneumaticCraft."
	]
	quest.CA00000000000018.quest_subtitle: "You've mastered Create"
	quest.CA00000000000018.title: "🏭 INDUSTRIAL EMPIRE"
