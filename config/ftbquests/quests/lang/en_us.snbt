	quest.A000000000000001.quest_desc: [
		"&6&lAPOTHEOSIS&r"
		""
		"The &caffix&r system — items with magical powers of increasing rarity."
		""
		"&aRarities:&r"
		"&7• Common (white)"
		"&7• Uncommon (green)"
		"&7• Rare (blue)"
		"&7• Epic (purple)"
		"&7• Mythic (orange)"
		"&7• Ancient (red)"
		"&7• &6Heirloom&r (yellow, legendary)"
		""
		"&aSystem:&r mob drops with affixes, &eSigil of Enhancement&r to reroll them, &eGem Cutting Table&r to craft gems, &eAugmenting Table&r to upgrade."
	]
	quest.A000000000000001.quest_subtitle: "Common → Heirloom"
	quest.A000000000000001.title: "💎 Apotheosis — Legendary Affixes"
