	quest.7A00000000000001.quest_desc: [
		"&6&lINDUSTRIAL STORAGE&r"
		""
		"Every factory needs a place to store raw materials and final products. This pack gives you &cmany options&r — each with its own progression."
		""
		"&aPhysical Storage (this chapter):&r"
		"&7• &fSophisticated Storage&r — tiered chests/barrels (Iron → Netherite)"
		"&7• &fFunctional Storage&r — individual drawers per item, with a controller"
		"&7• &fIron Chests&r — larger chests tier-by-tier"
		"&7• &fSophisticated Backpacks&r — portable storage"
		"&7• &fEnder Storage&r — chests linked by frequencies"
		"&7• &eTrash Cans + Travelers Backpack&r &7(optional)"
		""
		"&aDigital Storage (separate chapters):&r"
		"&7• &b💾 Refined Storage&r — simple digital network"
		"&7• &b💾 Applied Energistics 2 (AE2)&r — advanced digital network with auto-crafting"
		""
		"&7You don't need to do all trees. Pick 1 or do them all."
	]
	quest.7A00000000000001.quest_subtitle: "2605 Guarde tudo: baus, gavetas e mochilas"
	quest.7A00000000000001.title: "📦 Storage — Where to keep everything"
	quest.7A00000000000010.quest_desc: [
		"&fThe starting point for the Sophisticated tree.&r"
		""
		"&aThe basic barrel already accepts upgrades:&r Stack (more slots), Compaction (auto-compress), Magnet, etc."
