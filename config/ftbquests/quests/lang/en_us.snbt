	quest.1B4201991EE0CC14.quest_desc: [
		"&6&lWelcome, adventurer!&r"
		""
		"You are about to enter a world where &btechnology&r, &dmagic&r, and &ccombat&r meet in a single epic journey."
		""
		"&eThis pack is centered around a &6steampunk industry&e theme — gears, steam, tamed lightning, and plasma."
		""
