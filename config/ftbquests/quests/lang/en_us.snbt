	quest.69D2AE629E4CEC79.quest_subtitle: "Immersive Engineering"
	quest.69D2AE629E4CEC79.title: "IE Excavator"
	quest.69D56FF6D92C29BC.quest_desc: [
		"&bTier 3 — Niotic Crystal&r"
		""
		"&7Solar Panel niotic — versao niotic."
		"&7Construa de tier anterior + materials do tier atual."
	]
	quest.69D56FF6D92C29BC.quest_subtitle: "Solar Panel niotic"
	quest.69DE86E9648E5A43.quest_desc: [
		"&7&aTurbine Engine&7 — engine endgame de turbina."
		"&7Maior eficiência + maior SU output."
		""
		"&6Tip:&r alimente com gasoline pra max performance."
	]
	quest.69DE86E9648E5A43.quest_subtitle: "Turbina endgame"
	quest.6A00000000000001.quest_desc: [
		"&6&lMEKANISM&r"
		""
		"The most classic industrial mod — a direct successor to IC2/Tekkit. Everything here is &cscalable&r: each tier multiplies your capacity."
		""
		"&aTiers (lowest to highest):&r"
		"&7• &fBasic&r — Steel + Osmium"
		"&7• &fAdvanced&r — Osmium Compressor"
		"&7• &eElite&r — Refined Glowstone"
		"&7• &dUltimate&r — Refined Obsidian"
		""
		"&aOre processing (the famous 'macerator doubles'):&r"
		"&7• &fEnrichment&r → 1 ore = &c2 dusts&r"
		"&7• &fPurification&r → 1 ore = &c3 dusts&r (with oxygen)"
		"&7• &fInjection&r → 1 ore = &c4 dusts&r (with hydrogen chloride)"
		"&7• &dDigital Miner&r — remote auto-mining"
		""
		"&7Endgame: Mekasuit + Fusion Reactor + Antimatter."
	]
	quest.6A00000000000001.quest_subtitle: "&8Tier 0 — Awakening"
	quest.6A00000000000001.title: "🔬 Mekanism — The Chemical Industry"
	quest.6A00000000000002.quest_desc: [
		"&fThe base metal of Mekanism.&r"
		""
		"&7How to obtain:"
		"&7• 1 Iron Dust + Carbon in the &eMetallurgic Infuser&r → Enriched Iron"
		"&7• Repeat the process → Steel Dust"
		"&7• Smelt → Steel Ingot"
		""
		"&aTip:&r coal crushed in the Crusher = Carbon."
	]
	quest.6A00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.6A00000000000002.title: "Steel Ingot"
	quest.6A00000000000003.quest_desc: [
		"&fThe base block for Mekanism machines.&r"
		""
		"&7Recipe: 4 Steel Ingots + 4 Glass + 1 Osmium"
		""
		"&aIf KubeJS integration is active, this can be made via Sequenced Assembly from Create!"
	]
	quest.6A00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.6A00000000000003.title: "Steel Casing"
	quest.6A00000000000004.quest_desc: [
		"&aThe first Mekanism machine.&r"
		""
		"Combines items + 'infuse types' (Carbon, Redstone, Diamond, Tin, etc.) to create new alloys and materials."
		""
		"&7Useful for:&r Steel, Bronze, Refined Obsidian (in high tiers)."
	]
	quest.6A00000000000004.quest_subtitle: "&fTier 2 — Steam"
	quest.6A00000000000004.title: "Metallurgic Infuser"
	quest.6A00000000000005.quest_desc: [
		"&cYour first power source.&r"
		""
		"Burns coal, wood, or lava (lava = A LOT of energy)."
		""
		"&aTip:&r 1 lava bucket poured over a Heat Generator lasts a LONG time. Place an Electric Pump to automate it."
	]
	quest.6A00000000000005.quest_subtitle: "&fTier 2 — Steam"
	quest.6A00000000000005.title: "Heat Generator"
	quest.6A00000000000006.quest_desc: [
		"&aThe most important tier 1 machine.&r"
		""
		"&7• 1 Iron Ore → 2 Iron Dusts → 2 Iron Ingots (smelted)"
		"&7• Same applies to copper, gold, emerald, etc."
		""
		"&aThis DOUBLES your ore.&r Move to higher tiers to triple/quadruple it."
	]
	quest.6A00000000000006.quest_subtitle: "&fTier 2 — Steam"
	quest.6A00000000000006.title: "Enrichment Chamber"
	quest.6A00000000000007.quest_desc: [
		"&fMekanism's BatBox (IC2 style!).&r"
		""
		"Stores energy. Each side can be configured as input or output."
		""
		"&7Capacity: ~4M FE."
	]
	quest.6A00000000000007.quest_subtitle: "&fTier 2 — Steam"
	quest.6A00000000000007.title: "Basic Energy Cube"
	quest.6A00000000000008.quest_desc: [
		"&aWind power.&r"
		""
		"The higher you place it (up to Y=255), the more energy it generates."
		""
		"&7Renewable. No fuel required. Great passive income."
	]
	quest.6A00000000000008.quest_subtitle: "&bTier 3 — Electric"
	quest.6A00000000000008.title: "Wind Generator"
	quest.6A00000000000009.quest_desc: [
		"&eSolar power.&r"
		""
		"Works during the day. Build several in parallel for scale."
		""
		"&aHigh tier (Advanced Solar Generator) generates much more."
	]
	quest.6A00000000000009.quest_subtitle: "&bTier 3 — Electric"
	quest.6A00000000000009.title: "Solar Generator"
	quest.6A0000000000000A.quest_desc: [
		"&fDust → Ore.&r"
		""
		"The reverse of the Enrichment Chamber. Combines dust + cobblestone = ore."
		""
		"&aUseful in advanced automation (Cobblestone Generator loops)."
	]
	quest.6A0000000000000A.quest_subtitle: "&fTier 2 — Steam"
	quest.6A0000000000000A.title: "Combiner"
	quest.6A0000000000000B.quest_desc: [
		"&fIngot → Dust.&r"
		""
		"Crushes ingots back into dust (you lose 1, gain 1)."
		""
		"&aAlso makes: Bio Fuel, Carbon, Sulfur (for chemical reactions)."
	]
	quest.6A0000000000000B.quest_subtitle: "&fTier 2 — Steam"
	quest.6A0000000000000B.title: "Crusher"
	quest.6A0000000000000C.quest_desc: [
		"&aFurnace x8 — powered by electricity.&r"
		""
		"Smelts items in bulk. Combine it with the Crusher + Enrichment Chamber to automatically process entire ores."
	]
	quest.6A0000000000000C.quest_subtitle: "&bTier 3 — Electric"
	quest.6A0000000000000C.title: "Energized Smelter"
	quest.6A0000000000000D.quest_desc: [
		"&6Tier 2 — Advanced.&r"
		""
		"&fPurification Chamber&r uses &eOxygen&r (from an Electrolytic Separator) to triple ores."
		""
		"&7Setup: water → Electrolytic Separator → Oxygen + Hydrogen → Purification Chamber"
		""
		"&aTriples your output. Worth the investment."
	]
	quest.6A0000000000000D.quest_subtitle: "&bTier 3 — Electric"
	quest.6A0000000000000D.title: "Advanced Tier — Purification Chamber"
	quest.6A0000000000000E.quest_desc: [
		"&eTier 3 — Elite.&r"
		""
		"&fChemical Injection Chamber&r uses &eHydrogen Chloride&r (HCl) to quadruple ores."
		""
		"&7Chemical chain: Water + Energy → H + O → H + Cl → HCl → Inject"
		""
		"&aProcessing endgame. No loss."
	]
	quest.6A0000000000000E.quest_subtitle: "&dTier 4 — Advanced"
	quest.6A0000000000000E.title: "Elite Tier — Chemical Injection Chamber"
	quest.6A0000000000000F.quest_desc: [
		"&dTier 4 — Ultimate.&r"
		""
		"The apex of Mekanism machines. Absurd capacity, absurd speed."
		""
		"&7Materials:&r"
		"&7• &fRefined Glowstone&r (Elite tier)"
		"&7• &fRefined Obsidian&r (Ultimate tier)"
		""
		"&aThe Ultimate Energy Cube stores billions of FE."
	]
	quest.6A0000000000000F.quest_subtitle: "&dTier 4 — Advanced"
	quest.6A0000000000000F.title: "🏆 Ultimate Tier"
	quest.6A00000000000010.quest_desc: [
		"&aAutomated remote mining.&r"
		""
		"Configure which blocks to mine and the radius. The Digital Miner handles it all on its own — even across entire dimensions."
		""
		"&cExpensive&r but saves hours of labor."
	]
	quest.6A00000000000010.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000010.title: "Digital Miner (optional)"
	quest.6A00000000000011.quest_desc: [
		"&fMekanism's 'paxel'.&r"
		""
		"Pickaxe + Axe + Shovel in one item. Steel is only the initial tier — there's also Osmium, Refined Obsidian, etc."
		""
		"&aUseful for general mining."
	]
	quest.6A00000000000011.quest_subtitle: "&fTier 2 — Steam"
	quest.6A00000000000011.title: "Mekanism Tools — Steel Paxel (optional)"
	quest.6A00000000000012.quest_desc: [
		"&dPart 1/4 of the technological armor.&r"
		""
		"Accepts modules: Night Vision, Solar Recharge, Auto-Eat, Vision Enhancement, etc."
	]
	quest.6A00000000000012.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000012.title: "Mekasuit Helmet"
	quest.6A00000000000013.quest_desc: [
		"&dPart 2/4.&r"
		""
		"Modules: Charge Distributor, Jetpack, Gravity Modulating, Radiation Shielding."
	]
	quest.6A00000000000013.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000013.title: "Mekasuit Bodyarmor"
	quest.6A00000000000014.quest_desc: [
		"&dPart 3/4.&r"
		""
		"Modules: Mekasuit Pants Sprint, Step Assist, Locomotive Boosting."
	]
	quest.6A00000000000014.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000014.title: "Mekasuit Pants"
	quest.6A00000000000015.quest_desc: [
		"&dPart 4/4.&r"
		""
		"Modules: Hydraulic Propulsion, Magnetic Attraction, Frost Walker."
		""
		"&aFull set + modules = practically immortal."
	]
	quest.6A00000000000015.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000015.title: "Mekasuit Boots"
	quest.6A00000000000016.quest_desc: [
		"&cMultiblock fission reactor.&r"
		""
		"Build the structure, feed it Fissile Fuel (Uranium), and manage the temperature with coolant."
		""
		"&cWarning:&r overheating causes a MELTDOWN — devastating radiation."
		""
		"&aGenerates enormous amounts of heat → use Heat Generators or Boilers + Turbines to convert it into FE."
	]
	quest.6A00000000000016.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000016.title: "Fission Reactor"
	quest.6A00000000000017.quest_desc: [
		"&eMultiblock fusion reactor.&r"
		""
		"Fuses Deuterium + Tritium → Helium + ENERGY."
		""
		"&7Advanced setup, requires endgame Mekanism, but it's the most dense energy source in the mod."
		""
		"&aNo radiation. No meltdown. But it needs a hohlraum + laser to ignite."
	]
	quest.6A00000000000017.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A00000000000017.title: "Fusion Reactor"
	quest.6A00000000000A.quest_desc: ["Master all Materials items."]
	quest.6A00000000000A.quest_subtitle: "Category hub"
	quest.6A00000000000A.title: "Materials"
	quest.6A0000000000FFFF.quest_desc: [
		"&6&lTHE HIGHEST POINT OF MEKANISM&r"
		""
		"Antimatter Pellets are produced by an &eAntimatter Organizer&r — an endgame machine that requires the Ultimate tier + massive energy."
		""
		"Each pellet stores energy equivalent to a star."
		""
		"&aReward:&r 4× Antimatter Pellet + Netherite Block + 1500 XP."
		""
		"&7You've mastered the chemical industry. Now you can look towards: Powah Endgame, AE2 Quantum, or a full Mekasuit."
	]
	quest.6A0000000000FFFF.quest_subtitle: "&6Tier 5 — Endgame"
	quest.6A0000000000FFFF.title: "🏆 ANTIMATTER"
	quest.6A0237FADC519965.quest_desc: ["From a distance, it looks peaceful. Fields of golden wheat swaying beside a proud windmill. But don’t be deceived: the Illagers tend no crops for trade. Behind the rustic facade lies a nest of evil, their blades as sharp as the sickles they carry."]
	quest.6A0237FADC519965.quest_subtitle: "Find an Illager Windmill"
