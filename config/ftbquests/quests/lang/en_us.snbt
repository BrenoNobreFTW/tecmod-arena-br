	quest.DFFFFFFFFFFFFFFF.quest_desc: [
		"&6&l>>> COMPLETE MEKASUIT <<<&r"
		""
		"&fThe ultimate Mekanism suit."
		"&b• 4 pieces + plug-and-play modules"
		"&b• Flight, gravity, night vision"
		"&b• Huge capacitor"
		""
		"&aReward:&r MekaSuit set + 2000 XP."
	]
	quest.DFFFFFFFFFFFFFFF.quest_subtitle: "Mekanism endgame"
	quest.DFFFFFFFFFFFFFFF.title: "FULL MEKASUIT"
	quest.F100000000000001.quest_desc: [
		"&6&lTFMG&r"
		""
		"A Create addon that introduces a true &cINDUSTRIAL REVOLUTION&r. Diesel, gasoline, oil distillation, cast iron — all in pure steampunk style."
		""
		"&aUnique Materials:&r"
		"&7• &fCast Iron&r — molded iron"
		"&7• &fHeavy Plate&r — armored plating"
		"&7• &fIndustrial Iron Block&r — base block"
		""
		"&aSignature Machines:&r"
		"&7• &fIndustrial Blast Furnace&r — massive smeltery"
		"&7• &fDistillation Tower&r — oil refining"
		"&7• &fDiesel Engine&r — powerful motor"
		"&7• &fToolbox&r — handy storage"
	]
	quest.F100000000000001.quest_subtitle: "Pure industrial steampunk"
	quest.F100000000000001.title: "🛢️ TFMG — Things Folks Make Greater"
	quest.F100000000000002.quest_desc: [
		"&fCast Iron — the base of TFMG.&r"
		""
		"Crafted with Iron + Coal in a specific recipe. Stronger than normal iron."
	]
	quest.F100000000000002.title: "Cast Iron Ingot"
	quest.F100000000000003.quest_desc: [
		"&fArmored plate.&r"
		""
		"Press Cast Iron using a Mechanical Press. Needed for industrial machines."
	]
	quest.F100000000000003.title: "Heavy Plate"
	quest.F100000000000004.quest_desc: [
		"&aThe TFMG base block.&r"
		""
		"Combines Cast Iron + Heavy Plate. Used in all large machines."
	]
	quest.F100000000000004.title: "Industrial Iron Block"
	quest.F100000000000005.quest_desc: [
		"&aMassive smeltery.&r"
		""
		"Multiblock — smelts ores on an industrial scale. Faster and more efficient than a vanilla furnace."
	]
	quest.F100000000000005.title: "Industrial Blast Furnace"
	quest.F100000000000006.quest_desc: [
		"&aFractional distillation tower.&r"
		""
		"Vertical multiblock. Takes in &cCrude Oil&r and separates it into fractions:"
		"&7• Diesel (heavy fuel)"
		"&7• Gasoline (light fuel)"
		"&7• Lubricant"
		""
		"&aPure steampunk vibe."
	]
	quest.F100000000000006.quest_subtitle: "Oil refining"
	quest.F100000000000006.title: "Distillation Tower"
	quest.F100000000000007.quest_desc: [
		"&aDiesel/Gasoline motor.&r"
		""
		"Burns fuel to produce &eMASSIVE Rotation&r (kinetic) or energy."
		""
		"&7Replaces the Steam Engine for industrial setups."
	]
	quest.F100000000000007.title: "Diesel Engine"
	quest.F100000000000008.quest_desc: [
		"&aThe liquid fuels.&r"
		""
		"Output from the Distillation Tower. Diesel = more energy/time. Gasoline = faster."
		""
		"&7Combine with a Diesel Engine for a full industrial setup."
	]
	quest.F100000000000008.title: "Diesel and Gasoline"
	quest.F100000000000009.quest_desc: [
		"&fToolbox.&r"
		""
		"Carries tools and swaps them quickly. Industrial aesthetic."
	]
	quest.F100000000000009.title: "Toolbox (optional)"
	quest.F10000000000FFFF.quest_desc: [
		"&6&lTFMG COMPLETED&r"
		""
		"You've opened a refinery. Diesel Engines are running, and Distillation Towers are boiling oil. The Industrial Era has begun."
		""
		"&aReward:&r 8× Industrial Iron Block + 1000 XP."
	]
	quest.F10000000000FFFF.title: "🏆 INDUSTRIAL REVOLUTION"
	quest.F500000000000001.quest_desc: [
		"&6&lREFINED STORAGE&r"
		""
		"Inspired by AE2, but &awithout the hassle&r:"
		"&7• No channels"
		"&7• No separate Pattern Encoder"
		"&7• Everything is configured directly"
		""
		"&aCompare:&r"
		"&7• &eAE2&r — more technical, channels, Quantum Network, Spatial"
		"&7• &fRS&r — plug-and-play, easy to scale, great for beginners"
		""
		"&7You can use &fboth&r together! Mekanism Integration allows RS to store fluids/gases."
	]
	quest.F500000000000001.quest_subtitle: "Simpler than AE2, just as powerful"
	quest.F500000000000001.title: "💿 Refined Storage — The simple alternative"
	quest.F500000000000002.quest_desc: [
		"&fThe base ingredient for RS.&r"
		""
		"&7Recipe:&r 4 Iron + 4 Quartz (in a cross shape)."
	]
	quest.F500000000000002.title: "Quartz Enriched Iron"
	quest.F500000000000003.quest_desc: [
		"&fThe 'flexible ribbon' of processors.&r"
		""
		"A common component in almost all processors."
	]
	quest.F500000000000003.title: "Processor Binding"
	quest.F500000000000004.quest_desc: [
		"&aThe 3 processor tiers.&r"
		""
		"&7• &fBasic Processor&r — starting items"
		"&7• &fImproved Processor&r — Disk Drives, controllers"
		"&7• &eAdvanced Processor&r — Auto-crafters, Wireless Grid"
	]
	quest.F500000000000004.title: "RS Processors"
	quest.F500000000000005.quest_desc: [
		"&aThe central block of the network.&r"
		""
		"Accepts energy (FE) and distributes it to all components via cables. Compared to the AE2 Controller — RS is &emuch simpler&r."
		""
		"&7Only 1 Controller per network. Plugs directly into cables."
	]
	quest.F500000000000005.quest_subtitle: "The heart of the network"
	quest.F500000000000005.title: "RS Controller"
	quest.F500000000000006.quest_desc: [
		"&fConnects everything.&r"
		""
		"RS cables are simpler than AE2 — no channels, no dense cables. Just plug and play."
	]
	quest.F500000000000006.title: "RS Cable"
	quest.F500000000000007.quest_desc: [
		"&fThe box that holds the disks.&r"
		""
		"8 slots, each accepting 1 storage disk. Connect to the network cable."
	]
	quest.F500000000000007.title: "Disk Drive"
	quest.F500000000000008.quest_desc: [
		"&aStarting and mid-tier disks.&r"
		""
		"&7• 1k = 1,000 items"
		"&7• 4k = 4,000 items"
		"&7• 16k = 16,000 items"
		""
		"&aSimpler than AE2 — absolute quantities, without trading off item types."
	]
	quest.F500000000000008.title: "Storage Disks 1k → 16k"
	quest.F500000000000009.quest_desc: [
		"&aHigh tier.&r"
		""
		"64,000 items per disk. Anything above this is usually Mekanism Integration or specific modpacks."
	]
	quest.F500000000000009.title: "Storage Disk 64k"
	quest.F50000000000000A.quest_desc: [
		"&aThe primary interface.&r"
		""
		"Craft using items from the network, and see your entire storage. Equivalent to AE2's Crafting Terminal."
	]
	quest.F50000000000000A.title: "Crafting Grid"
	quest.F50000000000000B.quest_desc: [
		"&aWhere you create patterns.&r"
		""
		"Craft 'fictitious' items here to create patterns that go to the Auto-crafter."
		""
		"&aSimpler than AE2 — no dedicated encoding machine."
	]
	quest.F50000000000000B.title: "Pattern Grid"
	quest.F50000000000000C.quest_desc: [
		"&aThe equivalent of AE2's Pattern Provider + Molecular Assembler in a single block.&r"
		""
		"Insert patterns. When the network needs the resulting item, it crafts it automatically."
		""
		"&7Place several in parallel for scale."
	]
	quest.F50000000000000C.quest_subtitle: "Automated crafting"
	quest.F50000000000000C.title: "Auto-crafter"
	quest.F50000000000000D.quest_desc: [
		"&aRemote network access.&r"
		""
		"Keep it in your hotbar, hold right-click = opens the remote Crafting Grid. Excellent for mining."
	]
	quest.F50000000000000D.title: "Wireless Grid (optional)"
	quest.F50000000000000E.quest_desc: [
		"&fIntegrate external chests as storage.&r"
		""
		"External Storage treats other containers (chests, drawers, AE2, etc.) as part of your RS storage."
		""
		"&aUseful for:&r gradually migrating from chests to the network."
	]
	quest.F50000000000000E.title: "External Storage (optional)"
	quest.F500000000FFFFFF.quest_desc: [
		"&6&lMASTERY OF THE SIMPLE NETWORK&r"
		""
		"You built a complete network with auto-crafting + wireless access. Everything organized and automated."
		""
		"&7Reward:&r 4× 1024k Storage Disk + 800 XP."
		""
		"&aOptional advanced step:&r combine with &eRefined Storage Mekanism Integration&r to store Mekanism's chemical gases!"
	]
	quest.F500000000FFFFFF.title: "🏆 COMPLETE RS NETWORK"
	quest.FA00000000000001.quest_desc: ["&6&lFARMER'S DELIGHT&r\n\nAdvanced cooking. Meals that provide real buffs."]
	quest.FA00000000000001.title: "🍳 Farmer's Delight — Cooking"
	quest.FA00000000000002.quest_desc: ["&fKnife for cutting (on the Cutting Board). Required to debone meats."]
	quest.FA00000000000002.title: "Flint Knife"
	quest.FA00000000000003.quest_desc: ["&aCooking pot. Combines ingredients into dishes that give buffs."]
	quest.FA00000000000003.title: "Cooking Pot"
	quest.FA00000000000004.quest_desc: ["&fCutting board. Use with a Knife to process foods."]
	quest.FA00000000000004.title: "Cutting Board"
	quest.FA00000000000005.quest_desc: ["&6Basic FD food. High saturation."]
	quest.FA00000000000005.title: "Hamburger"
	quest.FA0000000000FFFF.quest_desc: ["&6&lENDGAME DISH&r — powerful buffs. &aReward:&r 800 XP."]
	quest.FA0000000000FFFF.title: "🏆 Dumplings"
	task.5566F83D3BCFC606.title: "Read about Mystical Agriculture"
