	# === SERENE SEASONS ===
	chapter.7B8C9D0E1F2A3B4C.title: "Serene Seasons - Seasons"
	quest.7B8C9D0E1F2A0001.title: "Master the Seasons"
	quest.7B8C9D0E1F2A0001.subtitle: "Spring, Summer, Fall, Winter"
	quest.7B8C9D0E1F2A0001.description: ["Serene Seasons adds 4 seasons to your world (each ~7 days long).","Each season changes weather, plant growth, and mob spawning.","Combined with Cold Sweat (Altitude addon), ambient temperature varies by season.","Use the Calendar to check the current season."]
	quest.7B8C9D0E1F2A0002.title: "Calendar"
	quest.7B8C9D0E1F2A0002.subtitle: "Know the current season"
	quest.7B8C9D0E1F2A0002.description: ["The Calendar shows the active season and day of the year.","Useful for planning planting, cold-weather expeditions, or seasonal mob hunting.","Also shows sub-seasons (early/mid/late) within each of the 4 main ones."]
	quest.7B8C9D0E1F2A0003.title: "Season Sensor"
	quest.7B8C9D0E1F2A0003.subtitle: "Automatic redstone by season"
	quest.7B8C9D0E1F2A0003.description: ["The Season Sensor emits a redstone signal based on the current season.","Configurable for specific seasons - perfect for farms that only run in summer, or heaters that fire in winter.","Combines with Create / Mekanism / IF for seasonal automation."]
	quest.7B8C9D0E1F2A0004.title: "Spring"
	quest.7B8C9D0E1F2A0004.subtitle: "Planting time"
	quest.7B8C9D0E1F2A0004.description: ["In spring, plants grow faster and trees sprout easily.","Take advantage to plant saplings and expand your farms.","Temperature: mild, no thermal stress."]
	quest.7B8C9D0E1F2A0005.title: "Summer"
	quest.7B8C9D0E1F2A0005.subtitle: "Abundant harvest - but hot"
	quest.7B8C9D0E1F2A0005.description: ["Summer brings abundant harvests (melon, sugarcane, pumpkin).","Beware: temperature rises and you may overheat without water and light armor.","In hot biomes, consider Chameleon armor (cooling)."]
	quest.7B8C9D0E1F2A0006.title: "Fall"
	quest.7B8C9D0E1F2A0006.subtitle: "Final harvest of the year"
	quest.7B8C9D0E1F2A0006.description: ["In fall, leaves drop and it's the last chance to harvest before winter.","Stockpile food, firewood, and insulating armor.","Special mobs may appear (biome-dependent)."]
	quest.7B8C9D0E1F2A0007.title: "Winter"
	quest.7B8C9D0E1F2A0007.subtitle: "Survive the cold"
	quest.7B8C9D0E1F2A0007.description: ["Winter freezes everything: plants stop growing, rivers turn to ice, snow covers the ground.","Without insulation (Goat Wool or Hoglin) you freeze in minutes.","Take advantage to collect ice, snow, and hunt nighttime mobs."]
	quest.7B8C9D0E1F2A0008.title: "Master of Seasons"
	quest.7B8C9D0E1F2A0008.subtitle: "Survived the full cycle"
	quest.7B8C9D0E1F2A0008.description: ["You've passed through all 4 seasons!","Combine Serene Seasons with Cold Sweat for a complete survival challenge.","Use the thermometer to monitor temperature as seasons change."]

	# === SURVIVAL MECHANICS ===
	chapter.8D9E0F1A2B3C4D5E.title: "Survival Mechanics"
	quest.8D9E0F1A2B3C0001.title: "Hardcore Survival"
	quest.8D9E0F1A2B3C0001.subtitle: "Mechanics that keep you alive"
	quest.8D9E0F1A2B3C0001.description: ["This chapter groups 5 mods that change how you survive:","- &cNot Enough Revives&r: knockdown system (B during bleed out)","- &7GraveStone&r: tombstone marks where you died","- &eComforts&r: sleeping bag and hammock for sleeping outdoors","- &9Forgiving Void&r: teleport when falling into the void","- &6Simple Burnout Torch&r: torches that burn out over time","Master these mechanics and you will never be just another lost adventurer."]
	quest.8D9E0F1A2B3C0002.title: "Not Enough Revives"
	quest.8D9E0F1A2B3C0002.subtitle: "Knockdown System"
	quest.8D9E0F1A2B3C0002.description: ["When you die, instead of actually dying, you enter knockdown state (bleeding out).","Press &cB&r to exit bleed out and respawn on your own (XP cost).","In multiplayer, another player can revive you with the Cross of Revival.","Game-changer for survival: you always have a second chance."]
	quest.8D9E0F1A2B3C0003.title: "Cross of Revival"
	quest.8D9E0F1A2B3C0003.subtitle: "Revive allies"
	quest.8D9E0F1A2B3C0003.description: ["Use in hand to revive a downed ally.","Crucial in raids and tough bosses.","Combine with Totem of Undying for maximum resilience."]
	quest.8D9E0F1A2B3C0004.title: "GraveStone"
	quest.8D9E0F1A2B3C0004.subtitle: "Your death leaves a mark"
	quest.8D9E0F1A2B3C0004.description: ["When you die, all your items go inside a Gravestone.","The Gravestone does not despawn (no vanilla 5-min drop timer).","You receive an Obituary with the exact death coordinates.","Guarantee you never lose a whole run to a silly death."]
	quest.8D9E0F1A2B3C0005.title: "Gravestone"
	quest.8D9E0F1A2B3C0005.subtitle: "Death containers"
	quest.8D9E0F1A2B3C0005.description: ["The gravestone is generated automatically when you die.","You can collect an extra one for decoration (or to mark NPC tombs)."]
	quest.8D9E0F1A2B3C0006.title: "Obituary"
	quest.8D9E0F1A2B3C0006.subtitle: "Map of your death"
	quest.8D9E0F1A2B3C0006.description: ["The Obituary points to your last gravestone.","Right-click to see exact coordinates.","Useful to recover items when you die far from home."]
	quest.8D9E0F1A2B3C0007.title: "Comforts"
	quest.8D9E0F1A2B3C0007.subtitle: "Mobile shelter"
	quest.8D9E0F1A2B3C0007.description: ["Sleeping Bags and Hammocks let you sleep on expeditions without needing a real bed.","Sleeping Bag: makes night pass, but does not set spawn point.","Hammock: needs Rope and Nail to hang between 2 blocks.","Available in 16 colors."]
	quest.8D9E0F1A2B3C0008.title: "Sleeping Bag"
	quest.8D9E0F1A2B3C0008.subtitle: "Sleep anywhere"
	quest.8D9E0F1A2B3C0008.description: ["Place, sleep, night passes.","Unlike vanilla bed, does NOT set spawn point.","Portable item - always carry one when exploring."]
	quest.8D9E0F1A2B3C0009.title: "Hammock"
	quest.8D9E0F1A2B3C0009.subtitle: "Net between trees"
	quest.8D9E0F1A2B3C0009.description: ["Hang between 2 blocks using Rope and Nail.","Style: tropical forest explorer.","Also does not set spawn point."]
	quest.8D9E0F1A2B3C000A.title: "Forgiving Void"
	quest.8D9E0F1A2B3C000A.subtitle: "Saved from the void"
	quest.8D9E0F1A2B3C000A.description: ["When falling into the void (y below -64), instead of dying instantly, you are teleported back.","Anti-frustration: no losing items to a silly fall.","Works in all dimensions (Nether/End)."]
	quest.8D9E0F1A2B3C000B.title: "Simple Burnout Torch"
	quest.8D9E0F1A2B3C000B.subtitle: "Torches that burn out"
	quest.8D9E0F1A2B3C000B.description: ["Vanilla torches were replaced: they now extinguish after a while (~3-4 minecraft days).","Burned-out torch becomes Extinguished Torch - reactivate with flint and steel.","Forces the player to plan permanent lighting (lantern, glowstone, jack o lantern, etc.)."]
	quest.8D9E0F1A2B3C000C.title: "Complete Survivor"
	quest.8D9E0F1A2B3C000C.subtitle: "Master of survival"
	quest.8D9E0F1A2B3C000C.description: ["You have mastered all the survival mechanics!","Combine with Cold Sweat (temperature) + Serene Seasons (seasons) and your world becomes a complete survival simulation.","Good luck out there."]
}
