	quest.D000000000000000.quest_desc: [
		"&6&lALL of Mekanism on a single map.&r"
		""
		"&7From Enrichment Chamber to the &cAntimatter Reactor&7."
		"&7Each flower is a category."
	]
	quest.D000000000000000.quest_subtitle: "Mekanism start"
	quest.D000000000000000.title: "Complete Mekanism"
	quest.D000000000000001.quest_desc: [
		"&6&lPNEUMATICCRAFT&r"
		""
		"The &cmost steampunk&r mod in the pack. Air pressure as fuel, programmable drones flying around the base, and a pneumatic HUD."
		""
		"&aConcepts:&r"
		"&7• &fPressure&r — measured in bars (atmospheres)"
		"&7• &fAir Compressor&r — generates pressure by burning fuel"
		"&7• &fPressure Chamber&r — multiblock for alchemy"
		"&7• &fDrones&r — PROGRAMMABLE flying robots (puzzles)"
		"&7• &fPneumatic Helmet&r — modular HUD"
		""
		"&7Unique:&r you learn by &eprogramming&r drones using puzzle pieces (similar to Logic Gates)."
	]
	quest.D000000000000001.quest_subtitle: "Thinking compressed air"
	quest.D000000000000001.title: "💨 PneumaticCraft Repressurized"
	quest.D000000000000002.quest_desc: [
		"&fThe plastic of PneumaticCraft.&r"
		""
		"Make it with a Plastic Plant + Pressure Chamber. Needed for almost everything."
	]
	quest.D000000000000002.title: "Plastic"
	quest.D000000000000003.quest_desc: [
		"&aThe 'cable' of PneumaticCraft.&r"
		""
		"Transmits pressurized air between machines. Different tiers hold more bar pressure."
	]
	quest.D000000000000003.title: "Pressure Tube"
	quest.D000000000000004.quest_desc: [
		"&fThe first source of pressure.&r"
		""
		"Burns fuels (coal, lava, oil) to generate pressure. Outputs to a Pressure Tube."
		""
		"&7Initial tier — limited in max pressure (~5 bar)."
	]
	quest.D000000000000004.title: "Air Compressor"
	quest.D000000000000005.title: "Advanced Air Compressor"
	quest.D000000000000006.quest_desc: [
		"&fThe structure of the Pressure Chamber.&r"
		""
		"Multiblock 4x4x4 (minimum). Walls + Glass + 1 Valve."
		""
		"&aFunction:&r alchemy/transmutation. Item inside + pressure = transformed item (Plastic, Diamond, etc.)"
	]
	quest.D000000000000006.title: "Pressure Chamber Walls"
	quest.D000000000000007.quest_desc: [
		"&aThe gateway.&r"
		""
		"The block where you drop items in and where the product comes out. Always 1 valve per chamber."
	]
	quest.D000000000000007.title: "Pressure Chamber Valve"
	quest.D000000000000008.quest_desc: [
		"&aPneumatic elevator.&r"
		""
		"Goes up/down using pressure. Decorative + functional."
	]
	quest.D000000000000008.title: "Elevator (optional)"
	quest.D000000000000009.quest_desc: [
		"&aPneumatic auto-crafting.&r"
		""
		"Combines items via robotic arms. High-tier PneumaticCraft automation."
	]
	quest.D000000000000009.title: "Assembly Controller"
	quest.D00000000000000A.quest_desc: [
		"&aModular tech armor.&r"
		""
		"Accepts modules: Coordinate Tracker, Air Search, Block Tracker, Entity Tracker, etc."
		""
		"&7Industrial detective visual — see pressure, tracking, and X-ray for ores."
	]
	quest.D00000000000000A.quest_subtitle: "Steampunk HUD"
	quest.D00000000000000A.title: "Pneumatic Helmet"
	quest.D00000000000000B.quest_desc: [
		"&dPROGRAMMABLE flying robot.&r"
		""
		"Use a Drone Programmer to set up logic with puzzle pieces:"
		"&7• Move to / Mine / Place / Pickup / Filter"
		""
		"&aThe drone executes forever. Can replace entire automation setups."
	]
	quest.D00000000000000B.title: "Drone (programmable)"
	quest.D00000000000005.quest_desc: [
		"&aTier 2 compressor.&r"
		""
		"More efficient, supports higher pressure (~20 bar). Required for advanced machines."
	]
	quest.D0000000000FFFFF.quest_desc: [
		"&6&lPNEUMATIC ENDGAME&r"
		""
		"The Logistics Drone handles complex logistics via puzzle programming. You programmed a robot that organizes your base all on its own."
		""
		"&aReward:&r Logistics Drone + 1000 XP."
	]
	quest.D0000000000FFFFF.title: "🏆 LOGISTICS DRONE"
