	quest.4F00000000000001.quest_desc: [
		"&6&lENDERIO&r"
		""
		"The &cmost classic&r tech mod from the IC2/Tekkit era. Specialized in &ealchemical alloys&r and &fconduits&r."
		""
		"&aFamous EnderIO Alloys:&r"
		"&7• &cRedstone Alloy&r — conduits"
		"&7• &eEnergetic Alloy&r — circuits"
		"&7• &dVibrant Alloy&r — endgame"
		"&7• &8Dark Steel&r — armor"
		"&7• &fEnd Steel&r — endgame"
		""
		"&aIconic Features:&r"
		"&7• &fCapacitor Bank&r — massive storage"
		"&7• &fConduits&r — power/items/fluids in a single block space"
		"&7• &fPowered Spawner&r — auto-mob farm"
		"&7• &fVacuum Chest&r — auto-collects items"
	]
	quest.4F00000000000001.quest_subtitle: "&8Tier 0 — Awakening"
	quest.4F00000000000001.title: "🌑 EnderIO — Dark Industry"
	quest.4F00000000000002.quest_desc: [
		"&fThe first EnderIO machine.&r"
		""
		"Combines ingredients into alloys. Doesn't need power (uses coal). It's your gateway to all other alloys."
	]
	quest.4F00000000000002.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000002.title: "Simple Alloy Smelter"
	quest.4F00000000000003.quest_desc: [
		"&cThe first alloy.&r"
		""
		"Recipe: 1 Iron + 1 Redstone + 1 Silicon (or similar)."
		""
		"&aUsed in:&r conduits, painted blocks, basic machine frames."
	]
	quest.4F00000000000003.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000003.title: "Redstone Alloy"
	quest.4F00000000000004.quest_desc: [
		"&eThe electric alloy.&r"
		""
		"Recipe: Redstone + Glowstone + Gold."
		""
		"&aUsed in:&r capacitors, energy conduits, tier 2 machines."
	]
	quest.4F00000000000004.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000004.title: "Energetic Alloy"
	quest.4F00000000000005.quest_desc: [
		"&dEndgame alloy.&r"
		""
		"Recipe: Energetic Alloy + Ender Pearl."
		""
		"&aUsed in:&r endgame capacitor banks, vibrant capacitors."
	]
	quest.4F00000000000005.quest_subtitle: "&7Tier 1 — Bronze"
	quest.4F00000000000005.title: "Vibrant Alloy"
	quest.4F00000000000006.quest_desc: [
		"&8Dark steel — technological armor.&r"
		""
		"Forged in the Alloy Smelter: Iron + Coal + Obsidian."
		""
		"&aUsed in:&r Dark Steel Armor (Mekasuit-like upgrades), Dark Steel Pickaxe, etc."
	]
	quest.4F00000000000006.quest_subtitle: "&fTier 2 — Steam"
	quest.4F00000000000006.title: "Dark Steel Ingot"
	quest.4F00000000000007.quest_desc: [
		"&fEndgame EnderIO metal.&r"
		""
		"Recipe: Dark Steel + End Stone + other rare materials."
		""
		"&aUsed in:&r End Steel Armor (the strongest in the mod), HV conduits."
	]
	quest.4F00000000000007.quest_subtitle: "&fTier 2 — Steam"
	quest.4F00000000000007.title: "🏆 End Steel Ingot"
	quest.4F00000000000008.quest_desc: [
		"&fThe classic EnderIO conduit.&r"
		""
		"Flexible cable that carries energy. Different tiers carry more. It looks neat (doesn't intrude on blocks)."
		""
		"&aCan combine with:&r Item Conduit and Fluid Conduit in the same block (use a Conduit Probe to organize them)."
	]
	quest.4F00000000000008.quest_subtitle: "&fTier 2 — Steam"
	quest.4F00000000000008.title: "Energy Conduit"
	quest.4F00000000000009.quest_desc: [
		"&aClassic EnderIO storage.&r"
		""
		"Multiblock — place several side by side and their capacity ADDS UP. Plug-and-play."
		""
		"&7Replace your Mekanism Energy Cube with this if you prefer the EnderIO style."
	]
	quest.4F00000000000009.quest_subtitle: "&fTier 2 — Steam"
	quest.4F00000000000009.title: "Capacitor Bank"
	quest.4F0000000000000A.quest_desc: [
		"&aAutomated mob farm.&r"
		""
		"Use a &eSoul Vial&r to capture a mob. Place it in the Powered Spawner. Spawns copies of the mob continuously."
		""
		"&7Combine with Killer Joe or similar for auto-loot."
	]
	quest.4F0000000000000A.quest_subtitle: "&fTier 2 — Steam"
	quest.4F0000000000000A.title: "Powered Spawner (optional)"
	quest.4F0000000000000B.quest_desc: [
		"&aChest that automatically vacuums items.&r"
		""
		"Place it near a farm. Dropped items within a radius are sucked into the chest."
		""
		"&7Useful for mob farms and cobblestone generators."
	]
	quest.4F0000000000000B.quest_subtitle: "&fTier 2 — Steam"
	quest.4F0000000000000B.title: "Vacuum Chest (optional)"
